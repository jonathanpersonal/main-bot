{
  "name": "discord-department-management-bot",
  "version": "1.0.0",
  "description": "Reusable Discord Department Management Bot template",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "verify:officer-command": "node scripts/verifyOfficerCommandSchema.js",
    "verify:google-entrypoint": "node scripts/verifyGoogleAppsScriptEntrypoint.js",
    "check:conflicts": "node scripts/checkNoConflictMarkers.js",
    "setup": "node scripts/setup-first-run.js",
    "check": "npm run check:conflicts && npm run check:syntax",
    "check:syntax": "node scripts/check-js-syntax.js"
  },
  "dependencies": {
    "discord.js": "^14.0.0",
    "dotenv": "^16.0.0",
    "mysql2": "^3.11.0",
    "node-cron": "^4.2.1"
  }
}
