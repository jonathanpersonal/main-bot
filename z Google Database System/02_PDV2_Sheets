function pdv2Spreadsheet_() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  if (!ss) throw new Error('No active spreadsheet found. Use this as a container-bound Apps Script attached to the Google Sheet database.');
  return ss;
}

function pdv2GetSheet_(sheetName) {
  var ss = pdv2Spreadsheet_();
  var sh = ss.getSheetByName(sheetName);
  if (!sh) sh = ss.insertSheet(sheetName);
  return sh;
}

function pdv2HeadersForSheet_(sheetName) {
  return PDV2.HEADERS[sheetName] || [];
}

function pdv2EnsureSheet_(sheetName) {
  var sh = pdv2GetSheet_(sheetName);
  var headers = pdv2HeadersForSheet_(sheetName);
  if (headers.length) pdv2EnsureHeaders_(sh, headers);
  pdv2ApplySheetControls_(sh);
  pdv2FormatSheet_(sh);
  return sh;
}

function pdv2EnsureHeaders_(sh, headers) {
  if (!headers || !headers.length) return;

  pdv2DeleteEmptyHeaderGapColumns_(sh);

  var lastCol = Math.max(sh.getLastColumn(), headers.length);
  var current = lastCol > 0 ? sh.getRange(1, 1, 1, lastCol).getValues()[0].map(pdv2String_) : [];
  var changed = false;

  if (sh.getLastRow() === 0 || current.join('') === '') {
    sh.getRange(1, 1, 1, headers.length).setValues([headers]);
    changed = true;
  } else {
    headers.forEach(function(header) {
      if (current.indexOf(header) < 0) {
        current.push(header);
        changed = true;
      }
    });
    if (changed) {
      sh.getRange(1, 1, 1, current.length).setValues([current]);
    }
  }

  if (changed) pdv2FormatSheet_(sh);
}

function pdv2DeleteEmptyHeaderGapColumns_(sh) {
  var lastCol = sh.getLastColumn();
  if (lastCol < 1) return 0;

  var lastRow = Math.max(sh.getLastRow(), 1);
  var values = sh.getRange(1, 1, lastRow, lastCol).getValues();
  var ranges = [];
  var start = null;
  var end = null;

  for (var col = lastCol; col >= 1; col--) {
    var header = pdv2String_(values[0][col - 1]);
    var hasData = false;
    for (var row = 1; row < values.length; row++) {
      if (pdv2String_(values[row][col - 1]) !== '') {
        hasData = true;
        break;
      }
    }

    if (!header && !hasData) {
      if (end === null) end = col;
      start = col;
    } else if (end !== null) {
      ranges.push([start, end - start + 1]);
      start = null;
      end = null;
    }
  }

  if (end !== null) ranges.push([start, end - start + 1]);

  ranges.forEach(function(range) {
    sh.deleteColumns(range[0], range[1]);
  });

  return ranges.reduce(function(total, range) { return total + range[1]; }, 0);
}

function pdv2ApplySheetControls_(sh) {
  if (!sh || sh.getName() !== PDV2.SHEETS.RANKS) return;

  var map = pdv2HeaderMap_(sh);
  ['Activity Exempt', 'Activity Cadet'].forEach(function(header) {
    var column = map[header];
    if (!column) return;

    var rowCount = Math.max(sh.getMaxRows() - 1, 1);
    sh.getRange(2, column, rowCount, 1).insertCheckboxes('TRUE', 'FALSE');
  });
}

function pdv2ColumnHasDataBelowHeader_(sh, column) {
  if (!sh || sh.getLastRow() < 2) return false;
  var values = sh.getRange(2, column, sh.getLastRow() - 1, 1).getValues();
  return values.some(function(row) {
    return pdv2String_(row[0]) !== '';
  });
}

function pdv2RepairActivityNoticesHeaders_() {
  var sh = pdv2GetSheet_(PDV2.SHEETS.ACTIVITY_NOTICES);
  var expected = PDV2.HEADERS.ActivityNotices || [];
  if (!expected.length) return pdv2Success_({ skipped: true, reason: 'No ActivityNotices headers configured.' });

  var warnings = [];
  var blankColumnsRemoved = 0;
  var rewritten = false;

  if (sh.getLastRow() <= 1) {
    sh.getRange(1, 1, 1, expected.length).setValues([expected]);
    if (sh.getLastColumn() > expected.length) {
      sh.getRange(1, expected.length + 1, 1, sh.getLastColumn() - expected.length).clearContent();
    }
    pdv2FormatSheet_(sh);
    return pdv2Success_({ rewritten: true, blankColumnsRemoved: 0, warnings: [] });
  }

  for (var col = sh.getLastColumn(); col >= 1; col--) {
    var header = pdv2String_(sh.getRange(1, col).getValue());
    if (header) continue;
    if (pdv2ColumnHasDataBelowHeader_(sh, col)) {
      warnings.push('Blank ActivityNotices header at column ' + col + ' has data below it; left in place.');
      continue;
    }
    sh.deleteColumn(col);
    blankColumnsRemoved++;
  }

  pdv2EnsureHeaders_(sh, expected);
  pdv2FormatSheet_(sh);

  if (warnings.length) {
    pdv2Log_('WARN', 'INSTALL', 'ACTIVITY_NOTICES_HEADER_GAP_WARNING', 'ActivityNotices has blank header columns with data below them.', { warnings: warnings });
  }

  return pdv2Success_({
    rewritten: rewritten,
    blankColumnsRemoved: blankColumnsRemoved,
    warnings: warnings,
    headersChecked: expected.length
  });
}

function pdv2FormatSheet_(sh) {
  if (!sh || sh.getLastColumn() < 1) return;
  sh.setFrozenRows(1);
  sh.getRange(1, 1, 1, sh.getLastColumn()).setFontWeight('bold');
  try { sh.autoResizeColumns(1, Math.min(sh.getLastColumn(), 12)); } catch (err) {}
}

function pdv2HeaderMap_(sh) {
  var lastCol = sh.getLastColumn();
  if (lastCol < 1) return {};
  var headers = sh.getRange(1, 1, 1, lastCol).getDisplayValues()[0];
  var map = {};
  headers.forEach(function(header, index) {
    var h = pdv2String_(header);
    if (h) map[h] = index + 1;
  });
  return map;
}

function pdv2RowToObject_(sh, rowNumber) {
  var map = pdv2HeaderMap_(sh);
  var headers = Object.keys(map).sort(function(a, b) { return map[a] - map[b]; });
  if (rowNumber < 2 || rowNumber > sh.getLastRow()) return null;
  var values = sh.getRange(rowNumber, 1, 1, sh.getLastColumn()).getValues()[0];
  var obj = { __rowNumber: rowNumber };
  headers.forEach(function(header) {
    obj[header] = values[map[header] - 1];
  });
  return obj;
}

function pdv2AppendObject_(sheetName, obj) {
  var sh = pdv2EnsureSheet_(sheetName);
  var map = pdv2HeaderMap_(sh);
  var headers = Object.keys(map).sort(function(a, b) { return map[a] - map[b]; });
  var row = headers.map(function(header) {
    return obj && obj.hasOwnProperty(header) ? obj[header] : '';
  });
  sh.appendRow(row);
  return sh.getLastRow();
}

function pdv2AppendObjects_(sheetName, objects) {
  objects = objects || [];
  if (!objects.length) return [];

  var sh = pdv2EnsureSheet_(sheetName);
  var map = pdv2HeaderMap_(sh);
  var headers = Object.keys(map).sort(function(a, b) { return map[a] - map[b]; });
  var rows = objects.map(function(obj) {
    return headers.map(function(header) {
      return obj && obj.hasOwnProperty(header) ? obj[header] : '';
    });
  });
  var startRow = sh.getLastRow() + 1;
  sh.getRange(startRow, 1, rows.length, headers.length).setValues(rows);

  return rows.map(function(_, index) { return startRow + index; });
}

function pdv2UpdateRowObject_(sheetName, rowNumber, updates) {
  var sh = pdv2EnsureSheet_(sheetName);
  var map = pdv2HeaderMap_(sh);
  Object.keys(updates || {}).forEach(function(header) {
    if (map[header]) sh.getRange(rowNumber, map[header]).setValue(updates[header]);
  });
  return pdv2RowToObject_(sh, rowNumber);
}

function pdv2FindRowByValue_(sheetName, headerName, value) {
  var sh = pdv2EnsureSheet_(sheetName);
  var map = pdv2HeaderMap_(sh);
  var col = map[headerName];
  if (!col) return 0;

  var lastRow = sh.getLastRow();
  if (lastRow < 2) return 0;

  var needle = pdv2String_(value);
  var values = sh.getRange(2, col, lastRow - 1, 1).getValues();
  for (var i = 0; i < values.length; i++) {
    if (pdv2String_(values[i][0]) === needle) return i + 2;
  }
  return 0;
}

function pdv2ListRows_(sheetName, options) {
  options = options || {};
  var sh = pdv2EnsureSheet_(sheetName);
  var lastRow = sh.getLastRow();
  if (lastRow < 2) return [];

  var map = pdv2HeaderMap_(sh);
  var headers = Object.keys(map).sort(function(a, b) { return map[a] - map[b]; });
  var values = sh.getRange(2, 1, lastRow - 1, sh.getLastColumn()).getValues();
  var rows = values.map(function(row, index) {
    var obj = { __rowNumber: index + 2 };
    headers.forEach(function(header) { obj[header] = row[map[header] - 1]; });
    return obj;
  });

  if (options.whereHeader && options.whereValue !== undefined) {
    rows = rows.filter(function(row) {
      return pdv2String_(row[options.whereHeader]) === pdv2String_(options.whereValue);
    });
  }

  if (options.status) {
    rows = rows.filter(function(row) {
      return pdv2String_(row.Status) === pdv2String_(options.status) || pdv2String_(row['Status']) === pdv2String_(options.status);
    });
  }

  if (options.limit) rows = rows.slice(0, Number(options.limit));
  return rows;
}

function pdv2SpreadsheetIdFromConfigValue_(value) {
  var raw = pdv2String_(value);
  if (!raw) return '';
  var match = raw.match(/\/spreadsheets\/d\/([A-Za-z0-9_-]+)/);
  return match ? match[1] : raw;
}

function pdv2RosterSpreadsheet_() {
  var configured = pdv2GetConfigValue_('ROSTER_SPREADSHEET_ID', PDV2.DEFAULTS.ROSTER_SPREADSHEET_ID);
  var spreadsheetId = pdv2SpreadsheetIdFromConfigValue_(configured);
  if (!spreadsheetId) {
    throw new Error('ROSTER_SPREADSHEET_ID is not configured. Add the external roster spreadsheet ID or URL in SystemConfig.');
  }
  return SpreadsheetApp.openById(spreadsheetId);
}

function pdv2ConfiguredRosterSheetNames_() {
  return [
    pdv2GetConfigValue_('ROSTER_MAIN_SHEET_NAME', PDV2.DEFAULTS.ROSTER_MAIN_SHEET_NAME),
    pdv2GetConfigValue_('ROSTER_PROBATIONARY_SHEET_NAME', PDV2.DEFAULTS.ROSTER_PROBATIONARY_SHEET_NAME)
  ].map(pdv2String_).filter(function(name, index, names) {
    return name && names.indexOf(name) === index;
  });
}

function pdv2RosterSyncSheetLog_(runId, event, message, meta) {
  if (!runId || typeof pdv2Log_ !== 'function') return;
  pdv2Log_('INFO', runId, event, message, meta || {});
}

function pdv2NormalizeHeaderName_(value) {
  return pdv2String_(value)
    .replace(/[\u2018\u2019\u201B\u2032]/g, "'")
    .replace(/[\u201C\u201D]/g, '"')
    .replace(/[^A-Za-z0-9]+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()
    .toUpperCase();
}

function pdv2RosterHeaderAliases_(sheetName) {
  var probationary = pdv2String_(sheetName).toLowerCase().indexOf('probationary') >= 0;
  var common = {
    CALLSIGN: ['CALLSIGN', 'CALL SIGN'],
    NAME: ['NAME', 'OFFICER NAME', 'DB NAME'],
    RANK: ['RANK', 'CURRENT RANK'],
    DATE_OF_ENTRY: ['DATE OF ENTRY', 'JOIN DATE', 'DATE JOINED'],
    CURRENT_CYCLE_HOURS: ["Cycle's Hours", 'Cycles Hours', 'Current Cycle Hours', 'Current Month Hours'],
    PUBLIC_NOTES: ['Public Notes'],
    INTERNAL_NOTES: ['Internal Notes'],
    DISCORD_ID: ['DISCORD ID', 'Discord ID', 'DISCORDID']
  };
  if (probationary) {
    common.CURRENT_MONTH_HOURS = common.CURRENT_CYCLE_HOURS;
    common.TRAINING_OFFICER = ['Training Officer', 'FTO', 'FTO Officer'];
    common.DAYS_REMAINING = ['Days Remaining'];
    common.NUMBER_OF_RAS = ["Number of RA's", 'Number of RAs', 'Ride Alongs', 'Ride-Alongs'];
  } else {
    common.DATE_OF_PROMOTION = ['DATE OF PROMOTION', 'PROMOTION DATE', 'LAST PROMOTION DATE'];
    common.PREVIOUS_CYCLE_HOURS = ['Previous Cycles hours', 'Previous Cycle Hours', 'Previous Cycles Hours'];
    common.ACTIVE_STATUS = ['ACTIVE STATUS'];
    common.DEPARTMENT_STATUS = ['DEPARTMENT STATUS'];
  }
  return common;
}

function pdv2FindHeaderColumn_(sheet, headerNames, options) {
  options = options || {};
  var headerRows = options.headerRows || [5, 6];
  var lastCol = sheet.getLastColumn();
  if (!sheet || lastCol < 1) return null;
  var aliases = (headerNames || []).map(pdv2NormalizeHeaderName_);
  var scanned = [];

  for (var r = 0; r < headerRows.length; r++) {
    var rowNumber = Number(headerRows[r]);
    if (!rowNumber || rowNumber > sheet.getLastRow()) continue;
    var row = sheet.getRange(rowNumber, 1, 1, lastCol).getValues()[0];
    for (var c = 0; c < row.length; c++) {
      var raw = pdv2String_(row[c]);
      if (!raw) continue;
      var normalized = pdv2NormalizeHeaderName_(raw);
      scanned.push({ row: rowNumber, column: c + 1, letter: pdv2ColumnLetter_(c + 1), value: raw, normalized: normalized });
      if (aliases.indexOf(normalized) >= 0) {
        return { row: rowNumber, column: c + 1, letter: pdv2ColumnLetter_(c + 1), value: raw, normalized: normalized };
      }
    }
  }
  return options.includeScanned ? { missing: true, aliases: aliases, scanned: scanned } : null;
}

function pdv2BuildRosterColumnMap_(sheet, options) {
  options = options || {};
  var headerRows = options.headerRows || [5, 6];
  var aliasesByKey = options.aliases || pdv2RosterHeaderAliases_(sheet.getName());
  var required = options.required || ['CALLSIGN', 'NAME', 'RANK', 'DISCORD_ID'];
  var columns = {};
  var missing = [];
  Object.keys(aliasesByKey).forEach(function(key) {
    var found = pdv2FindHeaderColumn_(sheet, aliasesByKey[key], { headerRows: headerRows });
    if (found) columns[key] = found;
    else if (required.indexOf(key) >= 0) missing.push({ key: key, aliases: aliasesByKey[key] });
  });
  return {
    sheetName: sheet.getName(),
    headerRows: headerRows,
    lastRow: sheet.getLastRow(),
    lastColumn: sheet.getLastColumn(),
    columns: columns,
    missingRequired: missing,
    ok: missing.length === 0
  };
}

function pdv2ColumnLetter_(col) {
  var letter = '';
  while (col > 0) {
    var rem = (col - 1) % 26;
    letter = String.fromCharCode(65 + rem) + letter;
    col = Math.floor((col - 1) / 26);
  }
  return letter;
}

function pdv2RosterDiagnosticCell_(row, col) {
  return { column: col, letter: pdv2ColumnLetter_(col), value: pdv2String_(row[col - 1]) };
}

function pdv2RunRosterColumnDiagnostics_() {
  return pdv2DiagnoseRosterColumns_();
}

function pdv2DiagnoseRosterColumns_() {
  var runId = pdv2GenerateId_('ROSTER-DIAG');
  var ss = pdv2RosterSpreadsheet_();
  var sheetNames = pdv2ConfiguredRosterSheetNames_();
  var result = { runId: runId, spreadsheetName: ss.getName(), sheetNames: sheetNames, sheets: [] };
  pdv2Log_('INFO', runId, 'ROSTER_DIAG_START', 'Starting roster column diagnostics.', { spreadsheetName: result.spreadsheetName, sheetNames: sheetNames });

  sheetNames.forEach(function(sheetName) {
    var sh = ss.getSheetByName(sheetName);
    var sheetResult = { sheetName: sheetName, found: !!sh };
    if (!sh) {
      result.sheets.push(sheetResult);
      pdv2Log_('WARN', runId, 'ROSTER_DIAG_SHEET_MISSING', 'Roster sheet not found.', { sheetName: sheetName });
      return;
    }
    sheetResult.columnMap = pdv2BuildRosterColumnMap_(sh, { headerRows: [5, 6] });
    sheetResult.ok = sheetResult.columnMap.ok;
    sheetResult.missingRequired = sheetResult.columnMap.missingRequired;
    result.sheets.push(sheetResult);
    pdv2Log_(sheetResult.ok ? 'INFO' : 'ERROR', runId, 'ROSTER_DIAG_SHEET_COMPLETE', sheetResult.ok ? 'Roster sheet diagnostics complete.' : 'Roster required headers missing.', sheetResult);
  });
  result.ok = result.sheets.every(function(item) { return item.found && item.ok; });
  pdv2Log_(result.ok ? 'INFO' : 'ERROR', runId, 'ROSTER_DIAG_COMPLETE', result.ok ? 'Roster column diagnostics complete.' : 'Roster column diagnostics found missing required headers.', result);
  try { SpreadsheetApp.flush(); } catch (err) {}
  return result;
}

function pdv2IsRosterHeaderOrLabelRow_(callsign, name, rank, discordId) {
  var values = [callsign, name, rank, discordId].map(pdv2NormalizeHeaderName_);
  return values.indexOf('INSIGNIA') >= 0 || values.indexOf('CALLSIGN') >= 0 || values.indexOf('CALL SIGN') >= 0 || values.indexOf('NAME') >= 0 || values.indexOf('RANK') >= 0 || values.indexOf('DISCORD ID') >= 0 || values.indexOf('DISCORDID') >= 0;
}

function pdv2ListRowsFromExistingSheet_(sh, runId) {
  if (!sh || sh.getLastRow() < 2 || sh.getLastColumn() < 1) return [];
  var mapResult = pdv2BuildRosterColumnMap_(sh, { headerRows: [5, 6] });
  if (!mapResult.ok) {
    var missing = mapResult.missingRequired.map(function(item) { return item.key + ' (aliases: ' + item.aliases.join(', ') + ')'; }).join('; ');
    throw new Error('Roster sheet "' + sh.getName() + '" is missing required headers: ' + missing);
  }
  var columns = mapResult.columns;
  var lastRow = sh.getLastRow();
  var lastCol = sh.getLastColumn();
  pdv2RosterSyncSheetLog_(runId, 'ROSTER_SYNC_SHEET_READ_START', 'Reading roster source sheet with detected headers.', { sheetName: sh.getName(), lastRow: lastRow, sheetLastColumn: lastCol, columnMap: mapResult });
  var values = sh.getRange(1, 1, lastRow, lastCol).getValues();
  var rows = [];
  values.forEach(function(row, index) {
    if (mapResult.headerRows.indexOf(index + 1) >= 0) return;
    var callsign = row[columns.CALLSIGN.column - 1];
    var name = row[columns.NAME.column - 1];
    var rank = row[columns.RANK.column - 1];
    var discordId = row[columns.DISCORD_ID.column - 1];
    if ([callsign, name, rank, discordId].join('').trim() === '') return;
    if (pdv2IsRosterHeaderOrLabelRow_(callsign, name, rank, discordId)) return;
    rows.push({ __rowNumber: index + 1, __sheetName: sh.getName(), 'Current Callsign': callsign, 'Name': name, 'Rank': rank, 'Discord ID': discordId });
  });
  pdv2RosterSyncSheetLog_(runId, 'ROSTER_SYNC_SHEET_READ_COMPLETE', 'Roster source sheet read complete.', { sheetName: sh.getName(), sourceRows: values.length, usableRows: rows.length, columnMap: mapResult });
  return rows;
}

function pdv2FindRosterHeaderRow_(sh) {
  var map = pdv2BuildRosterColumnMap_(sh, { headerRows: [5, 6] });
  return map.ok ? 5 : 0;
}

function pdv2CanonicalRosterRecord_(row, defaultDepartment) {
  row = row || {};
  var normalized = {
    __rowNumber: row.__rowNumber,
    __sheetName: row.__sheetName,
    'Status': pdv2Pick_(row, ['Status', 'STATUS', 'Roster Status', 'ACTIVE STATUS', 'Active'], ''),
    'Name': pdv2Pick_(row, ['Name', 'NAME', 'Officer Name', 'Full Name', 'Display Name'], ''),
    'Username': pdv2Pick_(row, ['Username', 'USERNAME', 'Discord Username', 'Discord Name'], ''),
    'Discord ID': pdv2Pick_(row, ['Discord ID', 'DISCORD ID', 'Discord Id', 'DiscordID', 'User ID', 'Member ID'], ''),
    'Rank': pdv2Pick_(row, ['Rank', 'RANK', 'Current Rank', 'Position'], ''),
    'Department': pdv2Pick_(row, ['Department', 'DEPARTMENT', 'Dept', 'Division'], defaultDepartment || 'main'),
    'Current Callsign': pdv2Pick_(row, ['Current Callsign', 'CURRENT CALLSIGN', 'Callsign', 'CALLSIGN', 'Call Sign', 'Unit Number', 'Unit', 'Badge Number', 'Badge'], ''),
    'Callsign Updated': pdv2Pick_(row, ['Callsign Updated', 'CALLSIGN UPDATED', 'Last Updated', 'Updated At'], '')
  };
  Object.keys(row).forEach(function(key) { if (!normalized.hasOwnProperty(key)) normalized[key] = row[key]; });
  return normalized;
}

function pdv2ListRosterRows_(runId) {
  pdv2RosterSyncSheetLog_(runId, 'ROSTER_SYNC_OPEN_ROSTER_START', 'Opening external roster spreadsheet.', { rosterSpreadsheetConfigured: !!pdv2GetConfigValue_('ROSTER_SPREADSHEET_ID', '') });
  var ss = pdv2RosterSpreadsheet_();
  pdv2RosterSyncSheetLog_(runId, 'ROSTER_SYNC_OPEN_ROSTER_COMPLETE', 'External roster spreadsheet opened.', { spreadsheetName: ss.getName() });
  var sheetNames = pdv2ConfiguredRosterSheetNames_();
  var rows = [];
  var missing = [];
  var defaultDepartment = pdv2GetConfigValue_('DEFAULT_DEPARTMENT_KEY', 'main') || 'main';
  sheetNames.forEach(function(sheetName) {
    pdv2RosterSyncSheetLog_(runId, 'ROSTER_SYNC_SHEET_LOOKUP', 'Looking up roster source sheet.', { sheetName: sheetName });
    var sh = ss.getSheetByName(sheetName);
    if (!sh) { missing.push(sheetName); return; }
    rows = rows.concat(pdv2ListRowsFromExistingSheet_(sh, runId).map(function(row) { return pdv2CanonicalRosterRecord_(row, defaultDepartment); }));
  });
  if (missing.length) throw new Error('Roster sheet tab(s) not found in external roster spreadsheet: ' + missing.join(', '));
  return rows;
}

function pdv2GetConfigValue_(key, fallback) {
  try {
    var row = pdv2FindRowByValue_(PDV2.SHEETS.SYSTEM_CONFIG, 'Key', key);
    if (!row) return fallback;
    var obj = pdv2RowToObject_(pdv2EnsureSheet_(PDV2.SHEETS.SYSTEM_CONFIG), row);
    var value = obj ? obj.Value : '';
    return value === '' || value === null || value === undefined ? fallback : value;
  } catch (err) {
    return fallback;
  }
}

function pdv2SetConfigValue_(key, value, description) {
  var row = pdv2FindRowByValue_(PDV2.SHEETS.SYSTEM_CONFIG, 'Key', key);
  var obj = {
    'Key': key,
    'Value': value,
    'Description': description || '',
    'Updated At': pdv2Now_()
  };
  if (row) return pdv2UpdateRowObject_(PDV2.SHEETS.SYSTEM_CONFIG, row, obj);
  pdv2AppendObject_(PDV2.SHEETS.SYSTEM_CONFIG, obj);
  return obj;
}
