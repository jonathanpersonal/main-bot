function pdv2InstallOrRepairSystem() {
  return pdv2WithLock_(function() {
    var checked = [];
    Object.keys(PDV2.SHEETS).forEach(function(key) {
      var sheetName = PDV2.SHEETS[key];
      pdv2EnsureSheet_(sheetName);
      checked.push(sheetName);
    });

    pdv2SeedSystemConfig_();
    pdv2SeedStarterConfig_();
    pdv2SeedInitialStaffAccess_();
    var rosterOptionRepair = pdv2RepairRosterOptionHeaderFormulas_();
    var activityNoticeRepair = pdv2RepairActivityNoticesHeaders_();

    pdv2Log_('INFO', 'INSTALL', 'SYSTEM_REPAIRED', 'Install/repair completed.', { sheetsChecked: checked.length });
    pdv2Audit_('SHEET_MENU', 'SYSTEM_REPAIRED', Session.getActiveUser().getEmail(), 'System', 'PDV2', '', {
      sheetsChecked: checked,
      rosterOptionRepair: rosterOptionRepair,
      activityNoticeRepair: activityNoticeRepair
    });

    return { ok: true, version: PDV2.VERSION, sheetsChecked: checked, rosterOptionRepair: rosterOptionRepair, activityNoticeRepair: activityNoticeRepair };
  });
}

