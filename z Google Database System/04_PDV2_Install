function pdv2SeedDefaultRosterOptions_() {
  pdv2MigrateDeprecatedRosterOptionStarters_();

  var starterOptions = [
    ['DIV_FTO', 'DIVISION', 'FTA/FTO', 'Division Membership', 5],
    ['DIV_GTF', 'DIVISION', 'GTF', 'Division Membership', 10],
    ['DIV_SWAT', 'DIVISION', 'SWAT', 'Division Membership', 20],
    ['DIV_SSD', 'DIVISION', 'SSD', 'Division Membership', 30],
    ['DIV_IA', 'DIVISION', 'IA', 'Division Membership', 40],
    ['DIV_TBD_1', 'DIVISION', 'TBD 1', 'Division Membership', 50],
    ['DIV_TBD_2', 'DIVISION', 'TBD 2', 'Division Membership', 60],
    ['DIV_TBD_3', 'DIVISION', 'TBD 3', 'Division Membership', 70],
    ['CERT_LEGAL', 'CERTIFICATION', 'LEGAL', 'Certifications', 5],
    ['CERT_RIFLE', 'CERTIFICATION', 'Rifle Cert', 'Certifications', 10],
    ['CERT_TBD_1', 'CERTIFICATION', 'TBD 1', 'Certifications', 20],
    ['CERT_TBD_2', 'CERTIFICATION', 'TBD 2', 'Certifications', 30],
    ['CERT_TBD_3', 'CERTIFICATION', 'TBD 3', 'Certifications', 40],
    ['CERT_TBD_4', 'CERTIFICATION', 'TBD 4', 'Certifications', 50]
  ];

  var added = 0;
  starterOptions.forEach(function(item) {
    var rowNumber = pdv2FindRowByValue_(PDV2.SHEETS.ROSTER_OPTIONS_CONFIG, 'OptionKey', item[0]);
    if (!rowNumber) {
      pdv2AppendObject_(PDV2.SHEETS.ROSTER_OPTIONS_CONFIG, {
        'OptionKey': item[0],
        'OptionType': item[1],
        'DisplayName': item[2],
        'RosterGroup': item[3],
        'RosterColumnLabel': '',
        'DatabaseColumnName': '',
        'DiscordRoleId': '',
        'Active': 'TRUE',
        'DisplayOrder': item[4],
        'Notes': 'Starter roster option. Edit per server.'
      });
      rowNumber = pdv2FindRowByValue_(PDV2.SHEETS.ROSTER_OPTIONS_CONFIG, 'OptionKey', item[0]);
      added++;
    } else {
      var existingOption = pdv2RowToObject_(pdv2EnsureSheet_(PDV2.SHEETS.ROSTER_OPTIONS_CONFIG), rowNumber) || {};
      var displayName = pdv2String_(existingOption.DisplayName);
      var shouldRefreshDisplayName = !displayName || (item[0].indexOf('_TBD_') >= 0 && displayName === 'TBD');
      pdv2UpdateRowObject_(PDV2.SHEETS.ROSTER_OPTIONS_CONFIG, rowNumber, {
        'OptionType': item[1],
        'DisplayName': shouldRefreshDisplayName ? item[2] : displayName,
        'RosterGroup': item[3],
        'DisplayOrder': item[4]
      });
    }
    pdv2SetRosterOptionConfigFormulasForRow_(rowNumber);
  });

  return { added: added };
}

function pdv2MigrateDeprecatedRosterOptionStarters_() {
  var rows = pdv2ListRows_(PDV2.SHEETS.ROSTER_OPTIONS_CONFIG);
  var changed = 0;
  rows.forEach(function(row) {
    var optionKey = pdv2Upper_(row.OptionKey);
    var optionType = pdv2Upper_(row.OptionType);
    var displayName = pdv2Upper_(row.DisplayName);
    var shouldDeactivate =
      optionKey === 'BUREAU_FTO' ||
      optionKey === 'BUREAU_LEGAL' ||
      (optionType === 'BUREAU_ASSIGNMENT' && (displayName === 'FTA/FTO' || displayName === 'LEGAL'));

    if (shouldDeactivate && pdv2Bool_(row.Active, true)) {
      pdv2UpdateRowObject_(PDV2.SHEETS.ROSTER_OPTIONS_CONFIG, row.__rowNumber, {
        'Active': 'FALSE',
        'Notes': pdv2String_(row.Notes) || 'Deprecated starter bureau option; use DIV_FTO or CERT_LEGAL.'
      });
      changed++;
    }
  });
  return { changed: changed };
}

function pdv2SeedInitialStaffAccess_() {
  var sh = pdv2EnsureSheet_(PDV2.SHEETS.STAFF_ACCESS);
  if (sh.getLastRow() > 1) return { added: false };

  var email = Session.getActiveUser().getEmail() || Session.getEffectiveUser().getEmail() || '';
  if (!email) return { added: false, reason: 'No active email detected.' };

  pdv2UpsertStaffAccess_({
    email: email,
    displayName: email,
    accessLevel: 'SUPER_ADMIN',
    active: true,
    notes: 'Auto-added during install because StaffAccess was empty.'
  });
  return { added: true, email: email };
}

