/*************************************************************
 * Department Database v2
 * File: 13_PDV2_Registration
 * -----------------------------------------------------------
 * Registration workflow processor for REGISTER_OFFICER bot
 * requests. This upserts the main Database sheet by Discord ID.
 *
 * This file also includes hard-route overrides for submit/process
 * so REGISTER_OFFICER cannot fall through to GENERIC_REQUEST_RECEIVED
 * if an older processor file is still present in the project.
 *************************************************************/

function pdv2RegisterOfficerFromBotRequest_(requestId, data) {
  data = data || {};
  var payload = data.payload && typeof data.payload === 'object' ? data.payload : {};

  pdv2Log_('INFO', requestId, 'REGISTER_OFFICER_PROCESSOR_START', 'REGISTER_OFFICER processor started.', {
    hasPayload: !!payload,
    payloadKeys: Object.keys(payload || {}).sort()
  });

  var source = pdv2Pick_(data, ['source'], 'DISCORD_BOT');
  var submittedBy = pdv2String_(pdv2Pick_(data, ['submittedByDiscordId', 'actorDiscordId'], ''));

  var discordId = pdv2String_(
    pdv2Pick_(payload, ['discordUserId', 'discordId', 'targetDiscordId'], '') ||
    pdv2Pick_(data, ['targetDiscordId', 'discordUserId', 'discordId'], '')
  );

  if (!discordId) {
    return pdv2Fail_('REGISTER_OFFICER is missing Discord ID.');
  }

  var cleanDisplayName = pdv2String_(
    pdv2Pick_(payload, ['cleanDisplayName', 'targetName', 'name', 'displayName'], '') ||
    pdv2Pick_(data, ['targetName', 'name', 'displayName'], '')
  );

  var discordUsername = pdv2String_(
    pdv2Pick_(payload, ['discordUsername', 'username'], '') ||
    pdv2Pick_(data, ['targetDiscordTag', 'discordUsername', 'username'], '')
  );

  var rankName = pdv2String_(
    pdv2Pick_(payload, ['rankName', 'rank', 'currentRank'], '') ||
    pdv2Pick_(data, ['newRank', 'rank'], '')
  );

  var joinDate = pdv2String_(pdv2Pick_(payload, ['joinDate', 'hireDate'], ''));
  var steam64 = pdv2String_(pdv2Pick_(payload, ['steam64', 'steamId'], ''));
  var email = pdv2String_(pdv2Pick_(payload, ['email'], ''));
  var department = pdv2String_(
    pdv2Pick_(payload, ['department', 'departmentKey'], '') ||
    pdv2Pick_(data, ['departmentKey'], '') ||
    pdv2GetConfigValue_('DEFAULT_DEPARTMENT_KEY', 'main')
  );
  var precinct = pdv2String_(pdv2Pick_(payload, ['precinct'], ''));
  var registerMode = pdv2String_(pdv2Pick_(payload, ['registerMode'], 'UNKNOWN'));

  var upsertResult = pdv2UpsertDatabaseRecord_({
    status: 'Active',
    name: cleanDisplayName,
    username: discordUsername,
    discordId: discordId,
    rank: rankName,
    steam64: steam64,
    joinDate: joinDate,
    email: email,
    precinct: precinct,
    department: department,
    notes: 'Registered from Discord bot. Mode: ' + registerMode
  }, {
    source: source,
    actor: submittedBy,
    requestId: requestId
  });

  if (!upsertResult.ok) {
    return upsertResult;
  }

  pdv2Audit_(
    source,
    'REGISTER_OFFICER',
    submittedBy,
    'Database',
    discordId,
    requestId,
    {
      registerMode: registerMode,
      cleanDisplayName: cleanDisplayName,
      rankName: rankName,
      joinDate: joinDate,
      steam64Provided: !!steam64,
      emailProvided: !!email,
      upsertMode: upsertResult.mode,
      rowNumber: upsertResult.rowNumber
    }
  );

  var botAction = pdv2CreateBotAction_({
    requestId: requestId,
    actionType: 'REGISTER_OFFICER_RESULT',
    targetDiscordId: discordId,
    payload: {
      message: 'Officer registration saved to Google Database.',
      requestId: requestId,
      discordId: discordId,
      name: cleanDisplayName,
      rank: rankName,
      mode: upsertResult.mode,
      rowNumber: upsertResult.rowNumber
    }
  });

  pdv2Log_('INFO', requestId, 'REGISTER_OFFICER_PROCESSOR_DONE', 'REGISTER_OFFICER processor completed.', {
    discordId: discordId,
    mode: upsertResult.mode,
    rowNumber: upsertResult.rowNumber
  });

  return pdv2Success_({
    message: 'Officer registration saved to Database.',
    registerMode: registerMode,
    upsert: upsertResult,
    createdAction: botAction
  });
}

function pdv2SubmitBotRequest_(data) {
  return pdv2WithLock_(function() {
    data = data || {};
    var payload = data.payload && typeof data.payload === 'object' ? data.payload : {};
    var actionType = pdv2Upper_(
      pdv2Pick_(data, ['actionType', 'action', 'type'], '') ||
      pdv2Pick_(payload, ['actionType', 'action', 'type'], '') ||
      'GOOGLE_TEST'
    );
    var requestId = pdv2GenerateId_('REQ');
    var actor = pdv2String_(pdv2Pick_(data, ['submittedByDiscordId', 'actorDiscordId', 'actor', 'userId']));
    var targetDiscordId = pdv2String_(
      pdv2Pick_(data, ['targetDiscordId', 'discordId', 'discordUserId', 'targetId'], '') ||
      pdv2Pick_(payload, ['targetDiscordId', 'discordId', 'discordUserId', 'targetId'], '')
    );
    var targetName = pdv2String_(
      pdv2Pick_(data, ['targetName', 'name', 'displayName'], '') ||
      pdv2Pick_(payload, ['targetName', 'cleanDisplayName', 'name', 'displayName'], '')
    );
    var storedPayload = data.payload && typeof data.payload === 'object' ? data.payload : data;

    var row = {
      'Request ID': requestId,
      'Created At': pdv2Now_(),
      'Updated At': pdv2Now_(),
      'Status': PDV2.STATUSES.REQUEST_RECEIVED,
      'Source': pdv2Pick_(data, ['source'], 'DISCORD_BOT'),
      'Action Type': actionType,
      'Submitted By Discord ID': actor,
      'Target Discord ID': targetDiscordId,
      'Target Name': targetName,
      'Old Rank': pdv2Pick_(data, ['oldRank'], ''),
      'New Rank': pdv2Pick_(data, ['newRank', 'rank'], ''),
      'Reason': pdv2Pick_(data, ['reason'], ''),
      'Payload JSON': pdv2SafeJson_(pdv2SanitizeForStorage_(storedPayload)),
      'Result JSON': '',
      'Error Message': '',
      'Completed At': ''
    };

    pdv2AppendObject_(PDV2.SHEETS.BOT_REQUESTS, row);
    pdv2Audit_(row.Source, 'BOT_REQUEST_RECEIVED', actor, 'BotRequests', requestId, requestId, {
      actionType: actionType,
      targetDiscordId: targetDiscordId
    });

    var processResult;
    if (actionType === 'REGISTER_OFFICER') {
      pdv2Log_('INFO', requestId, 'REGISTER_OFFICER_DIRECT_ROUTE_HIT', 'REGISTER_OFFICER direct route hit from 13_PDV2_Registration override.', {
        targetDiscordId: targetDiscordId,
        hasProcessor: typeof pdv2RegisterOfficerFromBotRequest_ === 'function'
      });
      processResult = pdv2RegisterOfficerFromBotRequest_(requestId, data);
    } else {
      processResult = pdv2ProcessBotRequest_(requestId, actionType, data);
    }

    var status = processResult.ok ? PDV2.STATUSES.REQUEST_PROCESSED : PDV2.STATUSES.REQUEST_FAILED;
    var reqRow = pdv2FindRowByValue_(PDV2.SHEETS.BOT_REQUESTS, 'Request ID', requestId);
    pdv2UpdateRowObject_(PDV2.SHEETS.BOT_REQUESTS, reqRow, {
      'Updated At': pdv2Now_(),
      'Status': status,
      'Result JSON': pdv2SafeJson_(processResult),
      'Error Message': processResult.ok ? '' : processResult.error,
      'Completed At': pdv2Now_()
    });

    return pdv2Success_({
      requestId: requestId,
      status: status,
      actionType: actionType,
      result: processResult
    });
  });
}

function pdv2ProcessBotRequest_(requestId, actionType, data) {
  try {
    data = data || {};
    actionType = pdv2Upper_(actionType || pdv2Pick_(data, ['actionType', 'action', 'type'], ''));

    var source = pdv2Pick_(data, ['source'], 'DISCORD_BOT');
    var actor = pdv2Pick_(data, ['submittedByDiscordId', 'actorDiscordId'], '');
    var targetDiscordId = pdv2Pick_(data, ['targetDiscordId', 'discordId', 'discordUserId'], '');
    var submittedOrTargetDiscordId = pdv2Pick_(data, ['submittedByDiscordId', 'targetDiscordId', 'discordId', 'discordUserId'], '');

    if (!actionType) {
      return pdv2Fail_('Bot request is missing actionType.');
    }

    if (actionType === 'REGISTER_OFFICER') {
      pdv2Log_('INFO', requestId, 'REGISTER_OFFICER_ROUTE_HIT', 'REGISTER_OFFICER processor route hit from 13_PDV2_Registration override.', {
        targetDiscordId: targetDiscordId,
        hasProcessor: typeof pdv2RegisterOfficerFromBotRequest_ === 'function'
      });
      return pdv2RegisterOfficerFromBotRequest_(requestId, data);
    }

    if (actionType === 'GOOGLE_TEST' || actionType === 'TEST' || actionType === 'TEST_GOOGLE_POST') {
      var testAction = pdv2CreateBotAction_({
        requestId: requestId,
        actionType: 'GOOGLE_TEST_RESULT',
        targetDiscordId: submittedOrTargetDiscordId,
        payload: {
          message: 'Google received the test request successfully.',
          requestId: requestId,
          serverName: pdv2GetConfigValue_('SERVER_NAME', PDV2.DEFAULTS.SERVER_NAME),
          instanceMode: PDV2.INSTANCE_MODE
        }
      });
      return pdv2Success_({ message: 'Test request received and pending bot action created.', createdAction: testAction });
    }

    if (actionType === 'PROMOTE' || actionType === 'DEMOTE' || actionType === 'SET_RANK') {
      var rankResult = pdv2SetDatabaseRank_(data, {
        source: source,
        actor: actor,
        requestId: requestId
      });
      var resultRecord = rankResult && rankResult.record ? rankResult.record : {};
      pdv2CreateBotAction_({
        requestId: requestId,
        actionType: 'OFFICER_MANAGEMENT_RESULT',
        targetDiscordId: targetDiscordId,
        payload: {
          actionType: actionType,
          requestId: requestId,
          guildId: pdv2Pick_(data, ['guildId'], '') || pdv2Pick_(payload, ['guildId'], ''),
          targetDiscordId: targetDiscordId,
          targetName: pdv2Pick_(resultRecord, ['Name'], '') || targetName,
          callsign: rankResult && rankResult.callsign ? rankResult.callsign.callsign : '',
          callsignAssigned: !!(rankResult && rankResult.callsign && rankResult.callsign.assigned),
          result: rankResult
        }
      });
      return rankResult;
    }

    if (actionType === 'TERMINATION' || actionType === 'RESIGNATION') {
      var statusValue = actionType === 'TERMINATION' ? 'Terminated' : 'Resigned';
      var statusResult = pdv2SetDatabaseStatus_(Object.assign({}, data, {
        status: statusValue,
        clearRank: true
      }), {
        source: source,
        actor: actor,
        requestId: requestId
      });
      pdv2AppendDisciplineRecord_(Object.assign({}, data, { actionType: actionType }), requestId);
      pdv2CreateBotAction_({
        requestId: requestId,
        actionType: 'OFFICER_STATUS_RESULT',
        targetDiscordId: targetDiscordId,
        payload: { actionType: actionType, requestId: requestId, result: statusResult }
      });
      return statusResult;
    }

    if (actionType === 'COACHING' || actionType === 'STRIKE') {
      var disciplineResult = pdv2AppendDisciplineRecord_(Object.assign({}, data, { actionType: actionType }), requestId);
      pdv2CreateBotAction_({
        requestId: requestId,
        actionType: 'DISCIPLINE_RECORD_RESULT',
        targetDiscordId: targetDiscordId,
        payload: { actionType: actionType, requestId: requestId, result: disciplineResult }
      });
      return disciplineResult;
    }

    if (actionType === 'TRAINING_COMPLETE' || actionType === 'APPLICATION_REVIEW' || actionType === 'CADET_TRAINING') {
      var trainingResult = pdv2AppendTrainingRecord_(Object.assign({}, data, { actionType: actionType }), requestId);
      pdv2CreateBotAction_({
        requestId: requestId,
        actionType: 'TRAINING_RECORD_RESULT',
        targetDiscordId: targetDiscordId,
        payload: { actionType: actionType, requestId: requestId, result: trainingResult }
      });
      return trainingResult;
    }

    pdv2CreateBotAction_({
      requestId: requestId,
      actionType: 'GENERIC_REQUEST_RECEIVED',
      targetDiscordId: submittedOrTargetDiscordId,
      payload: {
        message: 'Google received an unhandled request type. It was stored but no workflow has been attached yet.',
        actionType: actionType,
        requestId: requestId
      }
    });
    return pdv2Success_({ message: 'Request stored. No specific processor exists yet for ' + actionType + '.' });
  } catch (err) {
    pdv2Log_('ERROR', requestId, 'BOT_REQUEST_PROCESS_FAILED', String(err), {
      actionType: actionType,
      stack: err && err.stack ? String(err.stack) : ''
    });
    return pdv2Fail_(String(err));
  }
}
