/*************************************************************
 * Department Database v2
 * File: 07_PDV2_BotRequests
 *************************************************************/

function pdv2SubmitBotRequest_(data) {
  data = data || {};
  var payload = data.payload && typeof data.payload === 'object' ? data.payload : {};
  var actionType = pdv2Upper_(
    pdv2Pick_(data, ['actionType', 'action', 'type'], '') ||
    pdv2Pick_(payload, ['actionType', 'action', 'type'], '') ||
    'GOOGLE_TEST'
  );
  var requestId = pdv2GenerateId_('REQ');
  var actor = pdv2String_(pdv2Pick_(data, ['submittedByDiscordId', 'actorDiscordId', 'actor', 'userId']));
  var targetDiscordId = pdv2String_(
    pdv2Pick_(data, ['targetDiscordId', 'discordId', 'discordUserId', 'targetId'], '') ||
    pdv2Pick_(payload, ['targetDiscordId', 'discordId', 'discordUserId', 'targetId'], '')
  );
  var targetName = pdv2String_(
    pdv2Pick_(data, ['targetName', 'name', 'displayName'], '') ||
    pdv2Pick_(payload, ['targetName', 'cleanDisplayName', 'name', 'displayName'], '')
  );
  var storedPayload = data.payload && typeof data.payload === 'object' ? data.payload : data;

  var row = {
    'Request ID': requestId,
    'Created At': pdv2Now_(),
    'Updated At': pdv2Now_(),
    'Status': PDV2.STATUSES.REQUEST_RECEIVED,
    'Source': pdv2Pick_(data, ['source'], 'DISCORD_BOT'),
    'Action Type': actionType,
    'Submitted By Discord ID': actor,
    'Target Discord ID': targetDiscordId,
    'Target Name': targetName,
    'Old Rank': pdv2Pick_(data, ['oldRank'], ''),
    'New Rank': pdv2Pick_(data, ['newRank', 'rank'], ''),
    'Reason': pdv2Pick_(data, ['reason'], ''),
    'Payload JSON': pdv2SafeJson_(pdv2SanitizeForStorage_(storedPayload)),
    'Result JSON': '',
    'Error Message': '',
    'Completed At': ''
  };

  pdv2WithLock_(function() {
    pdv2AppendObject_(PDV2.SHEETS.BOT_REQUESTS, row);
  });
  pdv2Audit_(row.Source, 'BOT_REQUEST_RECEIVED', actor, 'BotRequests', requestId, requestId, {
    actionType: actionType,
    targetDiscordId: targetDiscordId
  });

  var processResult;
  if (actionType === 'REGISTER_OFFICER') {
    pdv2Log_('INFO', requestId, 'REGISTER_OFFICER_DIRECT_ROUTE_HIT', 'REGISTER_OFFICER direct route hit inside pdv2SubmitBotRequest_.', {
      targetDiscordId: targetDiscordId,
      hasProcessor: typeof pdv2RegisterOfficerFromBotRequest_ === 'function'
    });

    if (typeof pdv2RegisterOfficerFromBotRequest_ !== 'function') {
      processResult = pdv2Fail_('REGISTER_OFFICER processor is not installed. Add 13_PDV2_Registration and deploy a new web app version.');
    } else {
      processResult = pdv2RegisterOfficerFromBotRequest_(requestId, data);
    }
  } else {
    processResult = pdv2ProcessBotRequest_(requestId, actionType, data);
  }

  var status = processResult.ok ? PDV2.STATUSES.REQUEST_PROCESSED : PDV2.STATUSES.REQUEST_FAILED;
  var reqRow = pdv2FindRowByValue_(PDV2.SHEETS.BOT_REQUESTS, 'Request ID', requestId);
  pdv2UpdateRowObject_(PDV2.SHEETS.BOT_REQUESTS, reqRow, {
    'Updated At': pdv2Now_(),
    'Status': status,
    'Result JSON': pdv2SafeJson_(processResult),
    'Error Message': processResult.ok ? '' : processResult.error,
    'Completed At': pdv2Now_()
  });

  return pdv2Success_({
    requestId: requestId,
    status: status,
    actionType: actionType,
    result: processResult
  });
}

function pdv2ProcessBotRequest_(requestId, actionType, data) {
  try {
    data = data || {};
    actionType = pdv2Upper_(actionType || pdv2Pick_(data, ['actionType', 'action', 'type'], ''));

    var source = pdv2Pick_(data, ['source'], 'DISCORD_BOT');
    var actor = pdv2Pick_(data, ['submittedByDiscordId', 'actorDiscordId'], '');
    var targetDiscordId = pdv2Pick_(data, ['targetDiscordId', 'discordId', 'discordUserId'], '');
    var submittedOrTargetDiscordId = pdv2Pick_(data, ['submittedByDiscordId', 'targetDiscordId', 'discordId', 'discordUserId'], '');
    var payload = data.payload && typeof data.payload === 'object' ? data.payload : {};
    var targetName = pdv2String_(
      pdv2Pick_(data, ['targetName', 'name', 'displayName'], '') ||
      pdv2Pick_(payload, ['targetName', 'cleanDisplayName', 'name', 'displayName'], '')
    );

    if (!actionType) {
      return pdv2Fail_('Bot request is missing actionType.');
    }

    if (actionType === 'GOOGLE_TEST' || actionType === 'TEST' || actionType === 'TEST_GOOGLE_POST') {
      var testAction = pdv2CreateBotAction_({
        requestId: requestId,
        actionType: 'GOOGLE_TEST_RESULT',
        targetDiscordId: submittedOrTargetDiscordId,
        payload: {
          message: 'Google received the test request successfully.',
          requestId: requestId,
          serverName: pdv2GetConfigValue_('SERVER_NAME', PDV2.DEFAULTS.SERVER_NAME),
          instanceMode: PDV2.INSTANCE_MODE
        }
      });

      return pdv2Success_({
        message: 'Test request received and pending bot action created.',
        createdAction: testAction
      });
    }

    if (actionType === 'REGISTER_OFFICER') {
      pdv2Log_('INFO', requestId, 'REGISTER_OFFICER_ROUTE_HIT', 'REGISTER_OFFICER processor route hit inside pdv2ProcessBotRequest_.', {
        targetDiscordId: targetDiscordId,
        hasProcessor: typeof pdv2RegisterOfficerFromBotRequest_ === 'function'
      });

      if (typeof pdv2RegisterOfficerFromBotRequest_ !== 'function') {
        return pdv2Fail_('REGISTER_OFFICER processor is not installed. Add 13_PDV2_Registration and deploy a new web app version.');
      }

      return pdv2RegisterOfficerFromBotRequest_(requestId, data);
    }

    if (actionType === 'PROMOTE' || actionType === 'DEMOTE' || actionType === 'SET_RANK') {
      var rankResult = pdv2SetDatabaseRank_(data, {
        source: source,
        actor: actor,
        requestId: requestId
      });
      var resultRecord = rankResult && rankResult.record ? rankResult.record : {};

      pdv2CreateBotAction_({
        requestId: requestId,
        actionType: 'OFFICER_MANAGEMENT_RESULT',
        targetDiscordId: targetDiscordId,
        payload: {
          actionType: actionType,
          requestId: requestId,
          guildId: pdv2Pick_(data, ['guildId'], '') || pdv2Pick_(payload, ['guildId'], ''),
          targetDiscordId: targetDiscordId,
          targetName: pdv2Pick_(resultRecord, ['Name'], '') || targetName,
          callsign: rankResult && rankResult.callsign ? rankResult.callsign.callsign : '',
          callsignAssigned: !!(rankResult && rankResult.callsign && rankResult.callsign.assigned),
          result: rankResult
        }
      });

      return rankResult;
    }

    if (actionType === 'TERMINATION' || actionType === 'RESIGNATION') {
      var statusValue = actionType === 'TERMINATION' ? 'Terminated' : 'Resigned';

      var statusResult = pdv2SetDatabaseStatus_(Object.assign({}, data, {
        status: statusValue,
        clearRank: true
      }), {
        source: source,
        actor: actor,
        requestId: requestId
      });

      pdv2AppendDisciplineRecord_(Object.assign({}, data, {
        actionType: actionType
      }), requestId);

      pdv2CreateBotAction_({
        requestId: requestId,
        actionType: 'OFFICER_STATUS_RESULT',
        targetDiscordId: targetDiscordId,
        payload: {
          actionType: actionType,
          requestId: requestId,
          result: statusResult
        }
      });

      return statusResult;
    }

    if (actionType === 'COACHING' || actionType === 'STRIKE') {
      var disciplineResult = pdv2AppendDisciplineRecord_(Object.assign({}, data, {
        actionType: actionType
      }), requestId);

      pdv2CreateBotAction_({
        requestId: requestId,
        actionType: 'DISCIPLINE_RECORD_RESULT',
        targetDiscordId: targetDiscordId,
        payload: {
          actionType: actionType,
          requestId: requestId,
          result: disciplineResult
        }
      });

      return disciplineResult;
    }

    if (
      actionType === 'TRAINING_COMPLETE' ||
      actionType === 'APPLICATION_REVIEW' ||
      actionType === 'CADET_TRAINING' ||
      actionType === 'APPLICATION_ACCEPTED_FOR_TRAINING' ||
      actionType === 'CADET_ACCEPTED_FOR_TRAINING' ||
      actionType === 'TRAINING_PASSED' ||
      actionType === 'TRAINING_FAILED'
    ) {
      var trainingData = Object.assign({}, payload, data, { actionType: actionType });
      var trainingResult = pdv2AppendTrainingRecord_(trainingData, requestId);
      var cadetResult = null;
      var databaseResult = null;

      if (actionType === 'APPLICATION_ACCEPTED_FOR_TRAINING' || actionType === 'CADET_ACCEPTED_FOR_TRAINING') {
        cadetResult = pdv2UpsertCadetTracker_(trainingData, requestId);
      }

      if (actionType === 'TRAINING_PASSED' || (actionType === 'TRAINING_COMPLETE' && pdv2Upper_(pdv2Pick_(data, ['status'], '')) === 'PASSED')) {
        cadetResult = pdv2MarkCadetTrainingPassed_(trainingData, requestId);
        databaseResult = pdv2UpsertDatabaseRecord_(Object.assign({}, trainingData, { status: 'Active' }), {
          source: source,
          actor: actor,
          requestId: requestId
        });
      }

      var combinedTrainingResult = pdv2Success_({
        training: trainingResult,
        cadet: cadetResult,
        database: databaseResult,
        dbName: databaseResult && databaseResult.record ? databaseResult.record['Name'] : targetName,
        callsign: databaseResult && databaseResult.record ? databaseResult.record['Current Callsign'] : ''
      });

      pdv2CreateBotAction_({
        requestId: requestId,
        actionType: 'TRAINING_RECORD_RESULT',
        targetDiscordId: targetDiscordId,
        payload: {
          actionType: actionType,
          requestId: requestId,
          result: combinedTrainingResult
        }
      });

      return combinedTrainingResult;
    }

    if (actionType === 'PATROL_LOG' || actionType === 'DUTY_PATROL_LOG' || actionType === 'DUTY_CLOCK_IN' || actionType === 'DUTY_CLOCK_OUT') {
      var dutyResult = pdv2AppendPatrolLog_(Object.assign({}, payload, data), requestId);
      pdv2CreateBotAction_({ requestId: requestId, actionType: 'DUTY_RECORD_RESULT', targetDiscordId: targetDiscordId || submittedOrTargetDiscordId, payload: { actionType: actionType, requestId: requestId, result: dutyResult } });
      return dutyResult;
    }

    if (actionType === 'DUTY_TIMECARD_CORRECTION_APPROVED') {
      var correctionResult = pdv2ApplyTimecardCorrectionToPatrolLog_(Object.assign({}, payload, data), requestId);
      pdv2CreateBotAction_({ requestId: requestId, actionType: 'DUTY_RECORD_RESULT', targetDiscordId: targetDiscordId || submittedOrTargetDiscordId, payload: { actionType: actionType, requestId: requestId, result: correctionResult } });
      return correctionResult;
    }

    if (actionType === 'LOA_APPROVED' || actionType === 'LOA_SYNC_RUN') {
      var loaResult = pdv2UpdateDatabaseLoaStatus_(Object.assign({}, payload, data, { actionType: actionType }), requestId);
      pdv2CreateBotAction_({ requestId: requestId, actionType: 'GENERIC_LOG_RESULT', targetDiscordId: targetDiscordId || submittedOrTargetDiscordId, payload: { actionType: actionType, requestId: requestId, result: loaResult } });
      return loaResult;
    }

    if (actionType === 'ACTIVITY_REPORT_RUN') {
      var activityReportResult = pdv2ApplyActivityReportToDatabase_(Object.assign({}, payload, data), requestId);
      pdv2CreateBotAction_({ requestId: requestId, actionType: 'ACTIVITY_NOTICE_RESULT', targetDiscordId: submittedOrTargetDiscordId, payload: { actionType: actionType, requestId: requestId, result: activityReportResult } });
      return activityReportResult;
    }

    var loggingOnlyActions = ['DUTY_TIMECARD_CORRECTION_SUBMITTED','DUTY_TIMECARD_CORRECTION_DENIED','LOA_REQUEST_SUBMITTED','LOA_DENIED','RIDE_ALONG_FEEDBACK','ACTIVITY_STATUS_CHECK','TICKET_PANEL_POSTED','TICKET_CREATED','TICKET_CLAIMED','TICKET_RENAMED','TICKET_TRANSFERRED','TICKET_LOCKED_DOWN','TICKET_UNLOCKED','TICKET_TRANSCRIPT_SENT','TICKET_CLOSED','APPEAL_STARTED','APPEAL_SUBMITTED','APPEAL_REVIEW_STARTED','APPEAL_APPROVED','APPEAL_DENIED','APPEAL_CLOSED','CADET_APPROVED','CADET_DENIED','CADET_STATUS_UPDATED','CADET_DEADLINE_REMINDER_SENT','CADET_AUTO_TERMINATED','TRAINING_COMPLETED_PASS','TRAINING_COMPLETED_FAIL','PROBATION_STARTED','PROBATION_RIDEALONG_LOGGED','PROBATION_FEEDBACK_LOGGED','PROBATION_CYCLE_FAILED','PROBATION_EXTENSION_GRANTED','PROBATION_REMOVAL_REQUESTED','PROBATION_REMOVAL_APPROVED','PROBATION_PASSED','PROBATION_GRADUATED'];
    if (loggingOnlyActions.indexOf(actionType) >= 0) {
      pdv2Audit_(source, actionType, actor, 'BotRequests', requestId, requestId, { targetDiscordId: targetDiscordId, payload: payload });
      var trainingProbationResult = null;
      if (typeof pdv2HandleTrainingProbationWorkflowAction_ === 'function') {
        trainingProbationResult = pdv2HandleTrainingProbationWorkflowAction_(actionType, data, requestId);
      }
      pdv2CreateBotAction_({ requestId: requestId, actionType: actionType.indexOf('TICKET_') === 0 ? 'TICKET_RECORD_RESULT' : actionType.indexOf('APPEAL_') === 0 ? 'APPEAL_RECORD_RESULT' : 'GENERIC_LOG_RESULT', targetDiscordId: submittedOrTargetDiscordId, payload: { message: 'Request stored as logged event.', actionType: actionType, requestId: requestId } });
      return pdv2Success_({ message: 'Request stored as logged event.', workflow: trainingProbationResult });
    }

    if (
      actionType === 'ACTIVITY_NOTICE_ISSUED' ||
      actionType === 'ACTIVITY_STRIKE_ISSUED' ||
      actionType === 'ACTIVITY_NOTICE_RESOLVED' ||
      actionType === 'ACTIVITY_STRIKE_REMOVED'
    ) {
      var activityData = Object.assign({}, payload, data, { actionType: actionType });
      var activityResult = (
        actionType === 'ACTIVITY_NOTICE_RESOLVED' ||
        actionType === 'ACTIVITY_STRIKE_REMOVED'
      )
        ? pdv2ResolveActivityNotice_(activityData, requestId)
        : pdv2IssueActivityNotice_(activityData, requestId);

      pdv2CreateBotAction_({
        requestId: requestId,
        actionType: 'ACTIVITY_NOTICE_RESULT',
        targetDiscordId: targetDiscordId,
        payload: {
          actionType: actionType,
          requestId: requestId,
          discordId: pdv2ActivityNoticeDiscordId_(activityData),
          noticeLevel: pdv2Pick_(activityData, ['noticeLevel', 'strikeLevel'], ''),
          status: activityResult.ok ? 'PROCESSED' : 'FAILED',
          result: activityResult
        }
      });

      return activityResult;
    }

    pdv2CreateBotAction_({
      requestId: requestId,
      actionType: 'GENERIC_LOG_RESULT',
      targetDiscordId: submittedOrTargetDiscordId,
      payload: {
        message: 'Google received and logged an unhandled request type.',
        actionType: actionType,
        requestId: requestId
      }
    });

    return pdv2Success_({
      message: 'Request stored. No specific processor exists yet for ' + actionType + '.'
    });
  } catch (err) {
    pdv2Log_('ERROR', requestId, 'BOT_REQUEST_PROCESS_FAILED', String(err), {
      actionType: actionType,
      stack: err && err.stack ? String(err.stack) : ''
    });

    return pdv2Fail_(String(err));
  }
}

function pdv2GetRequestStatus_(requestId) {
  var row = pdv2FindRowByValue_(PDV2.SHEETS.BOT_REQUESTS, 'Request ID', requestId);
  if (!row) return pdv2Fail_('Request not found.', { requestId: requestId });
  var record = pdv2RowToObject_(pdv2EnsureSheet_(PDV2.SHEETS.BOT_REQUESTS), row);
  var actions = pdv2ListRows_(PDV2.SHEETS.BOT_ACTIONS).filter(function(action) {
    return pdv2String_(action['Request ID']) === pdv2String_(requestId);
  });
  return pdv2Success_({ request: record, actions: actions });
}
