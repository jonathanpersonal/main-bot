/*************************************************************
 * Department Database v2
 * File: 13_PDV2_WebApp
 * -----------------------------------------------------------
 * External API entry point for the Discord bot now and future UI
 * backend routes later.
 *************************************************************/

function doGet(e) {
  try {
    var data = pdv2ParseRequest_(e);
    if (!data.route && !data.action) {
      return pdv2JsonOutput_(pdv2Success_({
        status: 'ready',
        version: PDV2.VERSION,
        instanceMode: PDV2.INSTANCE_MODE,
        serverName: pdv2GetConfigValue_('SERVER_NAME', PDV2.DEFAULTS.SERVER_NAME),
        note: 'This is a single-server copied Google database instance. Use POST routes for bot actions.'
      }));
    }
    return pdv2JsonOutput_(pdv2RouteRequest_(data, {}));
  } catch (err) {
    return pdv2JsonOutput_(pdv2Fail_(String(err), { stack: err && err.stack ? String(err.stack) : '' }));
  }
}

function doPost(e) {
  var runId = pdv2GenerateId_('POST');
  try {
    var data = pdv2ParseRequest_(e);
    var route = data.route || data.action || '';
    var normalizedRoute = pdv2String_(route).toLowerCase();
    var suppressSuccessLog = normalizedRoute === 'getpendingbotactions';
    if (!suppressSuccessLog) pdv2Log_('INFO', runId, 'POST_START', 'doPost received.', {
      route: route,
      keys: Object.keys(data || {}).sort()
    });
    var result = pdv2RouteRequest_(data, { runId: runId });
    var isLockBusy = result && result.code === 'LOCK_BUSY';
    var debugLocks = pdv2Bool_(pdv2GetConfigValue_('DEBUG_LOCK_BUSY_LOGGING', 'FALSE'), false);
    if ((!suppressSuccessLog || !result.ok) && (!isLockBusy || debugLocks)) {
      pdv2Log_(result.ok ? 'INFO' : 'WARN', runId, 'POST_END', 'doPost completed.', { ok: result.ok, route: route, code: result.code || '' });
    }
    return pdv2JsonOutput_(result);
  } catch (err) {
    pdv2Log_('ERROR', runId, 'POST_ERROR', String(err), { stack: err && err.stack ? String(err.stack) : '' });
    return pdv2JsonOutput_(pdv2Fail_(String(err), { runId: runId }));
  }
}

function pdv2RouteRequest_(data, options) {
  data = data || {};
  options = options || {};

  var route = pdv2String_(pdv2Pick_(data, ['route', 'action'], 'ping'));
  var normalizedRoute = route.toLowerCase();

  if (normalizedRoute === 'ping') {
    var secretCheck = null;
    if (data.secret) secretCheck = pdv2RequireBotSecret_(data);
    return pdv2Success_({
      route: 'ping',
      version: PDV2.VERSION,
      instanceMode: PDV2.INSTANCE_MODE,
      serverName: pdv2GetConfigValue_('SERVER_NAME', PDV2.DEFAULTS.SERVER_NAME),
      secretConfigured: !!PropertiesService.getScriptProperties().getProperty(PDV2.SCRIPT_PROPERTY_BOT_SECRET),
      authorized: secretCheck ? !!secretCheck.ok : undefined
    });
  }

  if (!options.skipSecret) {
    var auth = pdv2RequireBotSecret_(data);
    if (!auth.ok) return auth;
  }

  var guildCheck = pdv2ValidateGuildIfConfigured_(data);
  if (!guildCheck.ok) return guildCheck;

  var botEnabled = pdv2Bool_(pdv2GetConfigValue_('BOT_API_ENABLED', 'TRUE'), true);
  var uiEnabled = pdv2Bool_(pdv2GetConfigValue_('UI_BACKEND_ENABLED', 'TRUE'), true);

  if (!botEnabled && normalizedRoute.indexOf('ui') !== 0) {
    return pdv2Fail_('Bot API routes are disabled in SystemConfig.');
  }

  if (normalizedRoute === 'syncranksconfig' || normalizedRoute === 'sync_ranks_config') return pdv2SyncRanksConfig_(data);
  if (normalizedRoute === 'submitbotrequest') return pdv2SubmitBotRequest_(data);
  if (normalizedRoute === 'getpendingbotactions') return pdv2GetPendingBotActions_(data);
  if (normalizedRoute === 'markbotactioncomplete') return pdv2MarkBotActionComplete_(data);
  if (normalizedRoute === 'markbotactionfailed') return pdv2MarkBotActionFailed_(data);
  if (normalizedRoute === 'getrequeststatus') return pdv2GetRequestStatus_(pdv2Pick_(data, ['requestId'], ''));
  if (normalizedRoute === 'lookup_officer') return pdv2LookupOfficerForBot_(data);
  if (normalizedRoute === 'sync_officer_from_google') return pdv2SyncOfficerFromGoogleForBot_(data);
  if (normalizedRoute === 'sync_officer_completed') return pdv2Success_({ recorded: true });
  if (normalizedRoute === 'sync_officer_failed') return pdv2Success_({ recorded: true });
  if (normalizedRoute === 'manual_officer_update') return pdv2ManualOfficerUpdateForBot_(data);
  if (normalizedRoute === 'manual_officer_update_completed') return pdv2Success_({ recorded: true });
  if (normalizedRoute === 'manual_officer_update_failed') return pdv2Success_({ recorded: true });
  if (normalizedRoute === 'import_existing_users') return pdv2ImportExistingUsersForBot_(data);

  if (normalizedRoute === 'upsertdatabaserecord') {
    return pdv2UpsertDatabaseRecord_(data.record || data, {
      source: pdv2Pick_(data, ['source'], 'API'),
      actor: pdv2Pick_(data, ['actor', 'submittedByDiscordId'], '')
    });
  }
  if (normalizedRoute === 'getdatabaserecord') return pdv2GetDatabaseRecordByDiscordId_(pdv2Pick_(data, ['discordId', 'targetDiscordId'], ''));
  if (normalizedRoute === 'searchdatabase') return pdv2SearchDatabase_(pdv2Pick_(data, ['query', 'q'], ''), pdv2Pick_(data, ['limit', 'max'], 25));
  if (normalizedRoute === 'listtrainingcadets') return pdv2ListTrainingCadets_(data);
  if (normalizedRoute === 'listprobationaryofficers') return pdv2ListProbationaryOfficers_(data);
  if (normalizedRoute === 'getprobationaryofficer') return pdv2GetProbationaryOfficer_(pdv2Pick_(data, ['discordId', 'targetDiscordId'], ''));

  if (normalizedRoute === 'listbotrequests') return pdv2ListSheetForUi_(PDV2.SHEETS.BOT_REQUESTS, pdv2Pick_(data, ['limit'], 100));
  if (normalizedRoute === 'listbotactions') return pdv2ListSheetForUi_(PDV2.SHEETS.BOT_ACTIONS, pdv2Pick_(data, ['limit'], 100));
  if (normalizedRoute === 'listauditlog') return pdv2ListSheetForUi_(PDV2.SHEETS.AUDIT_LOG, pdv2Pick_(data, ['limit'], 100));

  if (normalizedRoute.indexOf('ui') === 0 && !uiEnabled) return pdv2Fail_('UI backend routes are disabled in SystemConfig.');
  if (normalizedRoute === 'uigetbootstrapdata' || normalizedRoute === 'getuibootstrapdata') return pdv2GetUiBootstrapData_();
  if (normalizedRoute === 'uigetdashboarddata' || normalizedRoute === 'getuidashboarddata') return pdv2GetUiDashboardData_();
  if (normalizedRoute === 'uigetofficerprofile' || normalizedRoute === 'getofficerprofile') return pdv2GetOfficerProfileForUi_(pdv2Pick_(data, ['discordId', 'targetDiscordId'], ''));
  if (normalizedRoute === 'uisearchofficers' || normalizedRoute === 'searchofficerrecords') return pdv2SearchDatabase_(pdv2Pick_(data, ['query', 'q'], ''), pdv2Pick_(data, ['limit'], 25));

  return pdv2Fail_('Unknown route: ' + route, {
    supportedRoutes: [
      'ping',
      'submitBotRequest',
      'getPendingBotActions',
      'markBotActionComplete',
      'markBotActionFailed',
      'getRequestStatus',
      'upsertDatabaseRecord',
      'getDatabaseRecord',
      'searchDatabase',
      'listTrainingCadets',
      'listProbationaryOfficers',
      'getProbationaryOfficer',
      'getUiBootstrapData',
      'getUiDashboardData',
      'getOfficerProfile'
    ]
  });
}

/*************************************************************
 * Officer lookup/sync/manual/import API helpers added for bot.
 *************************************************************/
function pdv2OfficerApiRecord_(rowResult) {
  if (!rowResult || !rowResult.ok) return null;
  var r = rowResult.record || {};
  return {
    dbName: pdv2String_(r['Name']),
    discordId: pdv2String_(r['Discord ID']),
    discordUsername: pdv2String_(r['Username']),
    callsign: pdv2String_(r['Current Callsign']),
    rank: pdv2String_(r['Rank']),
    rankKey: pdv2String_(r['Rank Key'] || r['Rank']),
    status: pdv2String_(r['Status']),
    departmentStatus: pdv2String_(r['Department Status']),
    activeStatus: pdv2String_(r['Active Status']),
    department: pdv2String_(r['Department']),
    joinDate: pdv2String_(r['Join Date']),
    probationStatus: pdv2String_(r['Probation Status']),
    trainingOfficer: pdv2String_(r['Training Officer']),
    trainingStatus: pdv2String_(r['Training Status']),
    cadetDeadline: pdv2String_(r['Cadet Deadline']),
    probationStart: pdv2String_(r['Probation Start']),
    probationEnd: pdv2String_(r['Probation End']),
    latestChange: pdv2String_(r['Latest Change']),
    currentCycleHours: pdv2String_(r['Current Cycle Hours']),
    previousCycleHours: pdv2String_(r['Previous Cycle Hours']),
    publicNotes: pdv2String_(r['Public Notes']),
    internalNotes: pdv2String_(r['Internal Notes']),
    steam64: pdv2String_(r['Steam 64']),
    teamspeakId: pdv2String_(r['TeamSpeak ID']),
    recordId: pdv2String_(r['Record ID'] || rowResult.rowNumber),
    rowNumber: rowResult.rowNumber
  };
}

function pdv2LookupOfficerForBot_(data) {
  var discordId = pdv2String_(pdv2Pick_(data, ['discordId', 'targetDiscordId'], ''));
  if (!discordId) return pdv2Fail_('Missing Discord ID for officer lookup.');
  var found = pdv2GetDatabaseRecordByDiscordId_(discordId);
  if (!found.ok) return pdv2Success_({ found: false, discordId: discordId });
  return pdv2Success_({ found: true, officer: pdv2OfficerApiRecord_(found) });
}

function pdv2SyncOfficerFromGoogleForBot_(data) {
  return pdv2LookupOfficerForBot_(data);
}

function pdv2ManualOfficerUpdateForBot_(data) {
  var discordId = pdv2String_(pdv2Pick_(data, ['discordId', 'targetDiscordId'], ''));
  var field = pdv2String_(pdv2Pick_(data, ['field'], ''));
  var value = pdv2Pick_(data, ['value'], '');
  if (!discordId) return pdv2Fail_('Missing Discord ID for manual officer update.');
  if (!field) return pdv2Fail_('Missing field for manual officer update.');
  var map = {
    rank: 'Rank', callsign: 'Current Callsign', status: 'Status', activeStatus: 'Active Status',
    departmentStatus: 'Department Status', trainingStatus: 'Training Status', cadetStatus: 'Cadet Status',
    probationStatus: 'Probation Status', trainingOfficer: 'Training Officer', notes: 'Notes',
    publicNotes: 'Public Notes', internalNotes: 'Internal Notes', steam64: 'Steam 64', teamspeakId: 'TeamSpeak ID'
  };
  var header = map[field] || field;
  var row = pdv2FindRowByValue_(PDV2.SHEETS.DATABASE, 'Discord ID', discordId);
  if (!row) return pdv2Fail_('No Database record found for Discord ID ' + discordId + '.');
  var update = {}; update[header] = value; update['Latest Change'] = pdv2Now_();
  pdv2UpdateRowObject_(PDV2.SHEETS.DATABASE, row, update);
  pdv2Audit_('BOT', 'MANUAL_OFFICER_UPDATE', pdv2Pick_(data, ['requestedByDiscordId'], ''), 'Database', discordId, '', { field: field, header: header, reason: pdv2Pick_(data, ['reason'], '') });
  return pdv2Success_({ updated: true, found: true, officer: pdv2OfficerApiRecord_(pdv2GetDatabaseRecordByDiscordId_(discordId)) });
}

function pdv2ImportExistingUsersForBot_(data) {
  var users = data.users || [];
  var counts = { created: 0, updated: 0, skipped: 0, errors: [], records: [] };
  users.forEach(function(u) {
    try {
      var existing = pdv2GetDatabaseRecordByDiscordId_(u.discordId);
      var upsert = pdv2UpsertDatabaseRecord_({
        discordId: u.discordId,
        username: u.discordUsername,
        displayName: u.discordDisplayName,
        name: u.discordDisplayName,
        rank: u.detectedRankName || u.detectedRankKey || 'Unknown/Pending',
        steam64: u.steam64 || '',
        teamspeakId: u.teamspeakId || '',
        department: u.guildId,
        status: 'Active'
      }, { source: 'DISCORD_IMPORT', actor: data.requestedByDiscordId || u.importedByDiscordId || '' });
      if (!upsert.ok) { counts.errors.push({ discordId: u.discordId, error: upsert.error }); return; }
      if (existing.ok) counts.updated++; else counts.created++;
      counts.records.push({ discordId: u.discordId, mode: existing.ok ? 'updated' : 'created' });
    } catch (err) {
      counts.errors.push({ discordId: u.discordId, error: String(err) });
    }
  });
  return pdv2Success_(counts);
}
