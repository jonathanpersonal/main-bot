}

function pdv2UpsertStaffAccess_(input) {
  input = input || {};
  var email = pdv2String_(pdv2Pick_(input, ['email', 'Email']));
  if (!email) return pdv2Fail_('Missing email for StaffAccess.');

  var row = pdv2FindRowByValue_(PDV2.SHEETS.STAFF_ACCESS, 'Email', email);
  var obj = {
    'Email': email,
    'Discord ID': pdv2Pick_(input, ['discordId', 'Discord ID'], ''),
    'Display Name': pdv2Pick_(input, ['displayName', 'Display Name'], email),
    'Access Level': pdv2Pick_(input, ['accessLevel', 'Access Level'], 'VIEWER'),
    'Active': pdv2Bool_(pdv2Pick_(input, ['active', 'Active'], true), true) ? 'TRUE' : 'FALSE',
    'Notes': pdv2Pick_(input, ['notes', 'Notes'], ''),
    'Updated At': pdv2Now_()
  };

  if (row) {
    pdv2UpdateRowObject_(PDV2.SHEETS.STAFF_ACCESS, row, obj);
  } else {
    pdv2AppendObject_(PDV2.SHEETS.STAFF_ACCESS, obj);
  }
  return pdv2Success_({ email: email, access: obj });
}

function pdv2UpsertCadetTracker_(data, requestId) {
  data = data || {};
  var cadetData = data.cadetTracker && typeof data.cadetTracker === 'object' ? data.cadetTracker : {};
  data = Object.assign({}, cadetData, data);
  if (!pdv2Bool_(pdv2GetConfigValue_('CADET_TRACKER_ENABLED', 'TRUE'), true)) {
    return pdv2Success_({ skipped: true, reason: 'CADET_TRACKER_ENABLED is FALSE.' });
  }

  var discordId = pdv2String_(pdv2Pick_(data, ['targetDiscordId', 'officerDiscordId', 'discordId', 'Discord ID']));
  if (!discordId) return pdv2Fail_('Missing Discord ID for CadetTracker upsert.');

  var dateJoined = pdv2Pick_(data, ['dateJoined', 'acceptedAt'], pdv2Now_());
  var periodDays = Number(pdv2GetConfigValue_('CADET_DEFAULT_PERIOD_DAYS', '14') || 14);
  var endDate = pdv2Pick_(data, ['endDate'], '');
  if (!endDate && dateJoined) {
    var base = dateJoined instanceof Date ? new Date(dateJoined.getTime()) : new Date(dateJoined);
    if (!isNaN(base.getTime())) {
      base.setDate(base.getDate() + periodDays);
      endDate = base;
    }
  }

  var obj = {
    'Discord ID': discordId,
    'Name': pdv2Pick_(data, ['targetName', 'cleanDisplayName', 'officerDisplayName', 'name'], ''),
    'Date Joined': dateJoined,
    'End Date': endDate,
    'Trained?': pdv2Pick_(data, ['trained', 'Trained?'], pdv2GetConfigValue_('CADET_TRAINED_DEFAULT', 'FALSE')),
    'Days Remaining': '',
    'Current End Date': endDate,
    'Status': pdv2Pick_(data, ['cadetStatus', 'status'], pdv2GetConfigValue_('CADET_DEFAULT_STATUS', 'Pending Training')),
    'Name (DO NOT TOUCH)': pdv2Pick_(data, ['targetName', 'cleanDisplayName', 'officerDisplayName', 'name'], '')
  };

  var row = pdv2FindRowByValue_(PDV2.SHEETS.CADET_TRACKER, 'Discord ID', discordId);
  if (row) {
    if (pdv2Pick_(data, ['statusOverride'], '') !== '') obj['Status Override'] = pdv2Pick_(data, ['statusOverride'], '');
    if (pdv2Pick_(data, ['modifiedBy'], '') !== '') obj['Modified By:'] = pdv2Pick_(data, ['modifiedBy'], '');
    if (pdv2Pick_(data, ['manualEndDate'], '') !== '') obj['Manual End Date'] = pdv2Pick_(data, ['manualEndDate'], '');
    pdv2UpdateRowObject_(PDV2.SHEETS.CADET_TRACKER, row, obj);
  } else {
    pdv2AppendObject_(PDV2.SHEETS.CADET_TRACKER, Object.assign({}, obj, {
      'Status Override': pdv2Pick_(data, ['statusOverride'], ''),
      'Modified By:': pdv2Pick_(data, ['submittedByDiscordId', 'staffDiscordId', 'modifiedBy'], ''),
      'Manual End Date': pdv2Pick_(data, ['manualEndDate'], '')
    }));
  }
  pdv2Audit_('DISCORD_BOT', 'CADET_TRACKER_UPSERTED', pdv2Pick_(data, ['submittedByDiscordId'], ''), 'CadetTracker', discordId, requestId || '', { rowNumber: row || 'new' });
  return pdv2Success_({ discordId: discordId, rowNumber: row || pdv2FindRowByValue_(PDV2.SHEETS.CADET_TRACKER, 'Discord ID', discordId), cadet: obj });
}

function pdv2MarkCadetTrainingPassed_(data, requestId) {
  data = data || {};
  var discordId = pdv2String_(pdv2Pick_(data, ['targetDiscordId', 'discordId', 'Discord ID']));
  if (!discordId) return pdv2Fail_('Missing Discord ID for CadetTracker pass update.');
  var row = pdv2FindRowByValue_(PDV2.SHEETS.CADET_TRACKER, 'Discord ID', discordId);
  if (!row) {
    pdv2UpsertCadetTracker_(Object.assign({}, data, { trained: 'TRUE', cadetStatus: 'Trained/Passed' }), requestId);
    row = pdv2FindRowByValue_(PDV2.SHEETS.CADET_TRACKER, 'Discord ID', discordId);
  }
  var saved = pdv2UpdateRowObject_(PDV2.SHEETS.CADET_TRACKER, row, {
    'Trained?': 'TRUE',
    'Status': pdv2Pick_(data, ['cadetStatus'], 'Trained/Passed'),
    'Modified By:': pdv2Pick_(data, ['submittedByDiscordId', 'modifiedBy'], '')
  });
  pdv2Audit_('DISCORD_BOT', 'CADET_TRAINING_PASSED', pdv2Pick_(data, ['submittedByDiscordId'], ''), 'CadetTracker', discordId, requestId || '', {});
  return pdv2Success_({ discordId: discordId, cadet: saved });
}

function pdv2FormatMinutesAsHoursMinutes_(minutes) {
  minutes = Number(minutes) || 0;
  if (minutes <= 0) return '';
  minutes = Math.round(minutes);
  var hours = Math.floor(minutes / 60);
  var remainingMinutes = minutes % 60;
  return String(hours).padStart(2, '0') + ':' + String(remainingMinutes).padStart(2, '0');
}

function pdv2CurrentPatrolCycleKey_() {
  return pdv2String_(pdv2GetConfigValue_('HOURS_CURRENT_CYCLE_KEY', ''));
}

function pdv2SumPatrolMinutesForCycle_(discordId, cycleKey) {
  discordId = pdv2String_(discordId);
  cycleKey = pdv2String_(cycleKey);
  if (!discordId) return 0;

  return pdv2ListRows_(PDV2.SHEETS.PATROL_LOGS).reduce(function(total, row) {
    if (pdv2String_(row['Discord ID']) !== discordId) return total;
    if (cycleKey && pdv2String_(row['Cycle Key']) !== cycleKey) return total;
    return total + (Number(row['Duration Minutes']) || 0);
  }, 0);
}

function pdv2ConfigList_(key, defaultValue) {
  return pdv2String_(pdv2GetConfigValue_(key, defaultValue || ''))
    .split(/[\n,]+/)
    .map(function(item) { return pdv2String_(item).toLowerCase(); })
    .filter(function(item) { return item; });
}

function pdv2ActivityConfigKeyForRank_(prefix, rank) {
  return prefix + '_' + pdv2String_(rank)
    .replace(/[^A-Za-z0-9]+/g, '_')
    .replace(/^_+|_+$/g, '')
    .toUpperCase();
}

function pdv2GetActivityHoursThreshold_(prefix, rank, defaultKey, defaultValue) {
  var rankValue = pdv2GetConfigValue_(pdv2ActivityConfigKeyForRank_(prefix, rank), '');
  if (pdv2String_(rankValue) !== '') return Number(rankValue) || 0;
  return Number(pdv2GetConfigValue_(defaultKey, defaultValue)) || 0;
}

function pdv2CalculateActivityStatusFromHours_(record, totalMinutes, options) {
  options = options || {};
  record = record || {};
  var currentStatus = pdv2String_(record['Active Status']);
  if (options.preserveLoa !== false && currentStatus.toLowerCase() === 'loa') return 'LOA';

  var rank = pdv2String_(record.Rank || record['Rank']);
  var rankLower = rank.toLowerCase();
  var exemptRanks = pdv2ConfigList_('ACTIVITY_EXEMPT_RANKS', 'Chief, Deputy Chief, Commander');
  if (exemptRanks.indexOf(rankLower) >= 0) return 'Exempt';

  var newRanks = pdv2ConfigList_('ACTIVITY_NEW_RANKS', 'Recruit, Cadet');
  if (newRanks.indexOf(rankLower) >= 0) return 'New';

  var totalHours = (Number(totalMinutes) || 0) / 60;
  var activeHours = pdv2GetActivityHoursThreshold_('ACTIVITY_ACTIVE_HOURS', rank, 'ACTIVITY_ACTIVE_HOURS_DEFAULT', '2.5');
  var semiActiveHours = pdv2GetActivityHoursThreshold_('ACTIVITY_SEMI_ACTIVE_HOURS', rank, 'ACTIVITY_SEMI_ACTIVE_HOURS_DEFAULT', '2');

  if (totalHours >= activeHours) return 'Active';
  if (totalHours >= semiActiveHours) return 'Semi Active';
  return 'Inactive';
}

function pdv2UpdateDatabaseCurrentCycleHoursFromPatrolLogs_(discordId, cycleKey, requestId) {
  discordId = pdv2String_(discordId);
  if (!discordId) return pdv2Fail_('Missing Discord ID for Database patrol-hours update.');

  var row = pdv2FindRowByValue_(PDV2.SHEETS.DATABASE, 'Discord ID', discordId);
  if (!row) return pdv2Fail_('Database record not found for patrol-hours update.', { discordId: discordId });

  var totalMinutes = pdv2SumPatrolMinutesForCycle_(discordId, cycleKey);
  var totalHhMm = pdv2FormatMinutesAsHoursMinutes_(totalMinutes) || '00:00';
  var record = pdv2RowToObject_(pdv2EnsureSheet_(PDV2.SHEETS.DATABASE), row) || {};
  var updates = {
    'Current Cycle Hours': totalHhMm,
    'Latest Change': pdv2Now_()
  };
  if (pdv2Bool_(pdv2GetConfigValue_('ACTIVITY_STATUS_UPDATE_ON_PATROL_LOG', 'TRUE'), true)) {
    updates['Active Status'] = pdv2CalculateActivityStatusFromHours_(record, totalMinutes);
  }

  var saved = pdv2UpdateRowObject_(PDV2.SHEETS.DATABASE, row, updates);

  pdv2Audit_('DISCORD_BOT', 'DATABASE_PATROL_HOURS_UPDATED', discordId, 'Database', discordId, requestId || '', {
    cycleKey: cycleKey || '',
    totalMinutes: totalMinutes,
    totalHhMm: totalHhMm,
    activeStatus: updates['Active Status'] || ''
  });

  return pdv2Success_({
    discordId: discordId,
    cycleKey: cycleKey || '',
    totalMinutes: totalMinutes,
    totalHhMm: totalHhMm,
    activeStatus: updates['Active Status'] || '',
    record: saved
  });
}

function pdv2DateOnlyString_(value) {
  if (!value) return '';
  if (value instanceof Date) return Utilities.formatDate(value, pdv2Timezone_(), 'yyyy-MM-dd');
  var text = pdv2String_(value);
  if (/^\d{4}-\d{2}-\d{2}/.test(text)) return text.slice(0, 10);
  var date = new Date(text);
  if (isNaN(date.getTime())) return text;
  return Utilities.formatDate(date, pdv2Timezone_(), 'yyyy-MM-dd');
}

function pdv2DateOnlyComparable_(value) {
  if (!value) return '';
  var date = value instanceof Date ? value : new Date(value);
  if (isNaN(date.getTime())) return pdv2String_(value);
  return date.toISOString();
}

function pdv2IsTodayWithinDateRange_(startDate, endDate) {
  var today = Utilities.formatDate(new Date(), pdv2Timezone_(), 'yyyy-MM-dd');
  var start = pdv2DateOnlyString_(startDate);
  var end = pdv2DateOnlyString_(endDate);
  if (start && today < start) return false;
  if (end && today > end) return false;
  return true;
}

function pdv2UpdateDatabaseLoaStatus_(data, requestId) {
  data = data || {};
  var discordId = pdv2String_(pdv2Pick_(data, ['targetDiscordId', 'discordId', 'userId', 'Discord ID'], ''));
  if (!discordId) return pdv2Fail_('Missing Discord ID for LOA status update.');

  var row = pdv2FindRowByValue_(PDV2.SHEETS.DATABASE, 'Discord ID', discordId);
  if (!row) return pdv2Fail_('Database record not found for LOA status update.', { discordId: discordId });

  var actionType = pdv2Upper_(pdv2Pick_(data, ['actionType'], ''));
  var status = pdv2String_(pdv2Pick_(data, ['loaStatus', 'status'], ''));
  var syncAction = pdv2String_(pdv2Pick_(data, ['syncAction'], ''));
  var startDate = pdv2Pick_(data, ['startDate', 'loaStartDate'], '');
  var endDate = pdv2Pick_(data, ['endDate', 'loaEndDate'], '');
  var activeNow = pdv2IsTodayWithinDateRange_(startDate, endDate);
  var updates = { 'Latest Change': pdv2Now_() };

  if (actionType === 'LOA_APPROVED' && activeNow) {
    updates['Active Status'] = 'LOA';
  } else if (actionType === 'LOA_SYNC_RUN' && syncAction === 'role_added') {
    updates['Active Status'] = 'LOA';
  } else if (actionType === 'LOA_SYNC_RUN' && syncAction === 'role_removed') {
    var record = pdv2RowToObject_(pdv2EnsureSheet_(PDV2.SHEETS.DATABASE), row) || {};
    var cycleKey = pdv2CurrentPatrolCycleKey_();
    var totalMinutes = pdv2SumPatrolMinutesForCycle_(discordId, cycleKey);
    updates['Active Status'] = pdv2CalculateActivityStatusFromHours_(record, totalMinutes, { preserveLoa: false });
  } else {
    pdv2Audit_('DISCORD_BOT', 'DATABASE_LOA_STATUS_NO_CHANGE', discordId, 'Database', discordId, requestId || '', {
      actionType: actionType,
      status: status,
      startDate: startDate,
      endDate: endDate,
      activeNow: activeNow
    });
    return pdv2Success_({ discordId: discordId, changed: false, activeNow: activeNow });
  }

  var saved = pdv2UpdateRowObject_(PDV2.SHEETS.DATABASE, row, updates);
  pdv2Audit_('DISCORD_BOT', 'DATABASE_LOA_STATUS_UPDATED', discordId, 'Database', discordId, requestId || '', {
    actionType: actionType,
    status: status,
    activeStatus: updates['Active Status'],
    startDate: startDate,
    endDate: endDate
  });

  return pdv2Success_({
    discordId: discordId,
    changed: true,
    activeStatus: updates['Active Status'],
    record: saved
  });
}

function pdv2ApplyTimecardCorrectionToPatrolLog_(data, requestId) {
  data = data || {};
  var timecardId = pdv2String_(pdv2Pick_(data, ['timecardId', 'timecard_id', 'Timecard ID'], ''));
  var discordId = pdv2String_(pdv2Pick_(data, ['targetDiscordId', 'discordId', 'userId', 'Discord ID'], ''));
  if (!discordId) return pdv2Fail_('Missing Discord ID for timecard correction.');

  var requestedMinutes = Number(pdv2Pick_(data, ['requestedDurationMinutes', 'durationMinutes'], 0)) || 0;
  var requestedHours = pdv2Pick_(data, ['requestedDurationHours', 'durationHours'], requestedMinutes ? Math.round((requestedMinutes / 60) * 100) / 100 : '');
  var requestedHhMm = pdv2Pick_(data, ['requestedDurationHhMm', 'durationHhMm'], '') || pdv2FormatMinutesAsHoursMinutes_(requestedMinutes);
  var row = timecardId ? pdv2FindRowByValue_(PDV2.SHEETS.PATROL_LOGS, 'Timecard ID', timecardId) : 0;
  var patrolLogUpdated = false;
  var cycleKey = pdv2Pick_(data, ['cycleKey'], pdv2CurrentPatrolCycleKey_());

  if (!row) {
    var originalStart = pdv2DateOnlyComparable_(pdv2Pick_(data, ['originalClockInAt'], ''));
    var originalEnd = pdv2DateOnlyComparable_(pdv2Pick_(data, ['originalClockOutAt'], ''));
    var rows = pdv2ListRows_(PDV2.SHEETS.PATROL_LOGS);
    for (var i = rows.length - 1; i >= 0; i--) {
      if (pdv2String_(rows[i]['Discord ID']) !== discordId) continue;
      if (originalStart && pdv2DateOnlyComparable_(rows[i]['Started At']) !== originalStart) continue;
      if (originalEnd && pdv2DateOnlyComparable_(rows[i]['Ended At']) !== originalEnd) continue;
      row = rows[i].__rowNumber;
      break;
    }
  }

  if (row) {
    var patrolRecord = pdv2RowToObject_(pdv2EnsureSheet_(PDV2.SHEETS.PATROL_LOGS), row) || {};
    cycleKey = pdv2Pick_(patrolRecord, ['Cycle Key'], cycleKey);
    pdv2UpdateRowObject_(PDV2.SHEETS.PATROL_LOGS, row, {
      'Started At': pdv2Pick_(data, ['requestedClockInAt', 'startedAt'], patrolRecord['Started At']),
      'Ended At': pdv2Pick_(data, ['requestedClockOutAt', 'endedAt'], patrolRecord['Ended At']),
      'Duration Minutes': requestedMinutes || patrolRecord['Duration Minutes'],
      'Duration Hours': requestedHours || patrolRecord['Duration Hours'],
      'Duration HH:MM': requestedHhMm || patrolRecord['Duration HH:MM'],
      'Notes': pdv2Pick_(data, ['reason', 'notes'], patrolRecord.Notes),
      'Updated At': pdv2Now_()
    });
    patrolLogUpdated = true;
  }

  var databaseHoursResult = pdv2UpdateDatabaseCurrentCycleHoursFromPatrolLogs_(discordId, cycleKey, requestId);
  pdv2Audit_('DISCORD_BOT', 'TIMECARD_CORRECTION_APPLIED', discordId, 'PatrolLogs', timecardId || '', requestId || '', {
    timecardId: timecardId,
    patrolLogUpdated: patrolLogUpdated,
    requestedMinutes: requestedMinutes,
    requestedHhMm: requestedHhMm
  });

  return pdv2Success_({
    timecardId: timecardId,
    patrolLogUpdated: patrolLogUpdated,
    databaseHours: databaseHoursResult
  });
}

function pdv2ActivityReportStatusLabel_(status) {
  status = pdv2Upper_(status);
  if (status === 'ACTIVE') return 'Active';
  if (status === 'SEMI_ACTIVE') return 'Semi Active';
  if (status === 'INACTIVE') return 'Inactive';
  if (status === 'LOA') return 'LOA';
  if (status === 'EXEMPT') return 'Exempt';
  if (status === 'RECRUIT_TRAINING_PENDING') return 'New';
  if (status === 'ERROR') return 'Error';
  return pdv2String_(status);
}

function pdv2ApplyActivityReportToDatabase_(data, requestId) {
  data = data || {};
  var dryRun = pdv2Bool_(pdv2Pick_(data, ['dryRun'], false), false);
  var findings = data.findings && Array.isArray(data.findings) ? data.findings : [];
  var updated = 0;
  var skipped = 0;
  var missing = 0;
  var errors = [];

  if (dryRun) {
    pdv2Audit_('DISCORD_BOT', 'ACTIVITY_REPORT_DRY_RUN_RECEIVED', pdv2Pick_(data, ['submittedByDiscordId'], ''), 'Database', '', requestId || '', {
      cycleId: pdv2Pick_(data, ['cycleId'], ''),
      cycleStart: pdv2Pick_(data, ['cycleStart'], ''),
      cycleEnd: pdv2Pick_(data, ['cycleEnd'], ''),
      findingCount: findings.length
    });
    return pdv2Success_({ dryRun: true, findingCount: findings.length, updated: 0, skipped: findings.length });
  }

  findings.forEach(function(finding) {
    var discordId = pdv2String_(pdv2Pick_(finding, ['targetDiscordId', 'discordId', 'userId'], ''));
    if (!discordId) {
      skipped++;
      return;
    }

    var status = pdv2Upper_(pdv2Pick_(finding, ['activityStatus'], ''));
    if (status === 'ERROR') {
      skipped++;
      return;
    }

    var row = pdv2FindRowByValue_(PDV2.SHEETS.DATABASE, 'Discord ID', discordId);
    if (!row) {
      missing++;
      return;
    }

    try {
      var totalMinutes = Math.round((Number(pdv2Pick_(finding, ['totalSeconds'], 0)) || 0) / 60);
      var updates = {
        'Active Status': pdv2ActivityReportStatusLabel_(status),
        'Latest Change': pdv2Now_()
      };
      if (totalMinutes || pdv2Pick_(finding, ['totalHours'], '') !== '') {
        updates['Current Cycle Hours'] = pdv2FormatMinutesAsHoursMinutes_(totalMinutes) || '00:00';
      }
      pdv2UpdateRowObject_(PDV2.SHEETS.DATABASE, row, updates);
      updated++;
    } catch (err) {
      errors.push({ discordId: discordId, error: String(err) });
    }
  });

  pdv2Audit_('DISCORD_BOT', 'ACTIVITY_REPORT_DATABASE_UPDATED', pdv2Pick_(data, ['submittedByDiscordId'], ''), 'Database', '', requestId || '', {
    cycleId: pdv2Pick_(data, ['cycleId'], ''),
    cycleStart: pdv2Pick_(data, ['cycleStart'], ''),
    cycleEnd: pdv2Pick_(data, ['cycleEnd'], ''),
    findingCount: findings.length,
    updated: updated,
    skipped: skipped,
    missing: missing,
    errors: errors.slice(0, 10)
  });

  return pdv2Success_({
    dryRun: false,
    findingCount: findings.length,
    updated: updated,
    skipped: skipped,
    missing: missing,
    errors: errors
  });
}

function pdv2AppendPatrolLog_(data, requestId) {
  data = data || {};
  var patrolLogId = pdv2GenerateId_('PATROL');
  var discordId = pdv2Pick_(data, ['targetDiscordId', 'discordId'], '');
  var minutes = Number(pdv2Pick_(data, ['durationMinutes'], 0)) || 0;
  var hours = pdv2Pick_(data, ['durationHours'], minutes ? Math.round((minutes / 60) * 100) / 100 : '');
  var durationHhMm = pdv2Pick_(data, ['durationHhMm', 'durationHHMM', 'Duration HH:MM'], '') || pdv2FormatMinutesAsHoursMinutes_(minutes);
  var cycleKey = pdv2Pick_(data, ['cycleKey'], pdv2CurrentPatrolCycleKey_());
  pdv2AppendObject_(PDV2.SHEETS.PATROL_LOGS, {
    'PatrolLogId': patrolLogId,
    'Discord ID': discordId,
    'Name': pdv2Pick_(data, ['targetName', 'name'], ''),
    'Rank': pdv2Pick_(data, ['rank'], ''),
    'Department': pdv2Pick_(data, ['department', 'departmentKey'], pdv2GetConfigValue_('DEFAULT_DEPARTMENT_KEY', 'main')),
    'Patrol Type': pdv2Pick_(data, ['patrolType', 'type'], 'Duty'),
    'Timecard ID': pdv2Pick_(data, ['timecardId', 'timecard_id', 'Timecard ID'], ''),
    'Started At': pdv2Pick_(data, ['startedAt'], ''),
    'Ended At': pdv2Pick_(data, ['endedAt'], ''),
    'Duration Minutes': minutes || '',
    'Duration Hours': hours,
    'Duration HH:MM': durationHhMm,
    'Cycle Key': cycleKey,
    'Logged By Discord ID': pdv2Pick_(data, ['submittedByDiscordId', 'loggedByDiscordId'], ''),
    'Source': pdv2Pick_(data, ['source'], 'DISCORD_BOT'),
    'Request ID': requestId || '',
    'Notes': pdv2Pick_(data, ['notes'], ''),
    'Created At': pdv2Now_(),
    'Updated At': pdv2Now_()
  });
  var databaseHoursResult = minutes > 0
    ? pdv2UpdateDatabaseCurrentCycleHoursFromPatrolLogs_(discordId, cycleKey, requestId)
    : null;
  pdv2Audit_('DISCORD_BOT', 'PATROL_LOG_CREATED', pdv2Pick_(data, ['submittedByDiscordId'], ''), 'PatrolLogs', patrolLogId, requestId || '', {});
  return pdv2Success_({
    patrolLogId: patrolLogId,
    durationHhMm: durationHhMm,
    databaseHours: databaseHoursResult,
    hoursMode: pdv2GetConfigValue_('HOURS_MODE', 'FORMULA')
  });
}

function pdv2ActivityNoticeDiscordId_(data) {
  return pdv2String_(pdv2Pick_(data || {}, ['targetDiscordId', 'officerDiscordId', 'discordId', 'Discord ID'], ''));
}

function pdv2ActivityNoticeType_(data) {
  data = data || {};
  var explicit = pdv2String_(pdv2Pick_(data, ['noticeType', 'Notice Type'], ''));
  if (explicit) return explicit;
  var actionType = pdv2Upper_(pdv2Pick_(data, ['actionType'], ''));
  if (actionType.indexOf('STRIKE') >= 0) return 'STRIKE';
  return 'ACTIVITY';
}

function pdv2FindActiveActivityNoticeRow_(discordId, noticeType, noticeLevel) {
  var rows = pdv2ListRows_(PDV2.SHEETS.ACTIVITY_NOTICES);
  var typeUpper = pdv2Upper_(noticeType);
  var levelUpper = pdv2Upper_(noticeLevel);
  for (var i = rows.length - 1; i >= 0; i--) {
    var row = rows[i];
    if (pdv2String_(row['Discord ID']) !== pdv2String_(discordId)) continue;
    if (pdv2Upper_(row.Status) !== 'ACTIVE') continue;
    if (typeUpper && pdv2Upper_(row['Notice Type']) !== typeUpper) continue;
    if (levelUpper && pdv2Upper_(row['Notice Level']) !== levelUpper) continue;
    return row.__rowNumber;
  }
  return 0;
}

function pdv2AppendActivityNoticeRecord_(data, requestId) {
  data = data || {};
  var noticeId = pdv2GenerateId_('NOTICE');
  var discordId = pdv2ActivityNoticeDiscordId_(data);
  var now = pdv2Now_();
  var notice = {
    'NoticeId': noticeId,
    'Discord ID': discordId,
    'Name': pdv2Pick_(data, ['targetName', 'officerDisplayName', 'name'], ''),
    'Rank': pdv2Pick_(data, ['rank', 'Rank'], ''),
    'Notice Type': pdv2ActivityNoticeType_(data),
    'Notice Level': pdv2Pick_(data, ['noticeLevel', 'strikeLevel'], ''),
    'Reason': pdv2Pick_(data, ['reason'], ''),
    'Issued By Discord ID': pdv2Pick_(data, ['submittedByDiscordId', 'issuedByDiscordId'], ''),
    'Issued By Name': pdv2Pick_(data, ['submittedByDiscordTag', 'issuedByTag', 'issuedByName'], ''),
    'Issued At': pdv2Pick_(data, ['issuedAt'], now),
    'Expires At': pdv2Pick_(data, ['expiresAt'], ''),
    'Status': pdv2Pick_(data, ['status'], 'Active'),
    'Resolved At': pdv2Pick_(data, ['resolvedAt'], ''),
    'Resolved By Discord ID': pdv2Pick_(data, ['resolvedByDiscordId'], ''),
    'Request ID': requestId || '',
    'Source': pdv2Pick_(data, ['source'], 'DISCORD_BOT'),
    'Notes': pdv2Pick_(data, ['notes'], ''),
    'Created At': now,
    'Updated At': now
  };
  var rowNumber = pdv2AppendObject_(PDV2.SHEETS.ACTIVITY_NOTICES, notice);
  return pdv2Success_({ noticeId: noticeId, rowNumber: rowNumber, notice: notice });
}

function pdv2UpdateDatabaseActivityNoticeSummary_(data, requestId) {
  data = data || {};
  var discordId = pdv2ActivityNoticeDiscordId_(data);
  if (!discordId) return pdv2Fail_('Missing Discord ID for activity notice summary update.');

  var row = pdv2FindRowByValue_(PDV2.SHEETS.DATABASE, 'Discord ID', discordId);
  if (!row) {
    return pdv2Success_({
      discordId: discordId,
      databaseUpdated: false,
      warning: 'No Database officer row found for Discord ID ' + discordId + '.'
    });
  }

  var clear = pdv2Bool_(pdv2Pick_(data, ['clearSummary'], false), false);
  var updates = clear ? {
    'Activity Notice Level': '',
    'Activity Notice Reason': '',
    'Activity Notice Issued At': '',
    'Activity Notice Expires At': '',
    'Activity Notice Issued By': '',
    'Latest Change': pdv2Now_()
  } : {
    'Activity Notice Level': pdv2Pick_(data, ['noticeLevel', 'Notice Level'], ''),
    'Activity Notice Reason': pdv2Pick_(data, ['reason', 'Reason'], ''),
    'Activity Notice Issued At': pdv2Pick_(data, ['issuedAt', 'Issued At'], pdv2Now_()),
    'Activity Notice Expires At': pdv2Pick_(data, ['expiresAt', 'Expires At'], ''),
    'Activity Notice Issued By': pdv2Pick_(data, ['submittedByDiscordId', 'issuedByDiscordId', 'Issued By Discord ID'], ''),
    'Latest Change': pdv2Now_()
  };
  var departmentStatus = pdv2Pick_(data, ['departmentStatus'], '');
  if (!clear && departmentStatus) updates['Department Status'] = departmentStatus;

  var saved = pdv2UpdateRowObject_(PDV2.SHEETS.DATABASE, row, updates);
  pdv2Audit_(pdv2Pick_(data, ['source'], 'DISCORD_BOT'), clear ? 'DATABASE_ACTIVITY_NOTICE_CLEARED' : 'DATABASE_ACTIVITY_NOTICE_UPDATED', pdv2Pick_(data, ['submittedByDiscordId', 'issuedByDiscordId', 'Issued By Discord ID', 'resolvedByDiscordId'], ''), 'Database', discordId, requestId || '', updates);
  return pdv2Success_({ discordId: discordId, databaseUpdated: true, record: saved });
}

function pdv2IssueActivityNotice_(data, requestId) {
  data = data || {};
  var discordId = pdv2ActivityNoticeDiscordId_(data);
  if (!discordId) return pdv2Fail_('Missing Discord ID for activity notice issue.');

  var noticeType = pdv2ActivityNoticeType_(data);
  var noticeLevel = pdv2Pick_(data, ['noticeLevel', 'strikeLevel'], '');
  var existingRow = pdv2FindActiveActivityNoticeRow_(discordId, noticeType, noticeLevel);
  if (existingRow) {
    var existing = pdv2RowToObject_(pdv2EnsureSheet_(PDV2.SHEETS.ACTIVITY_NOTICES), existingRow);
    var summary = pdv2UpdateDatabaseActivityNoticeSummary_(Object.assign({}, data, {
      noticeLevel: existing['Notice Level'],
      reason: existing.Reason,
      issuedAt: existing['Issued At'],
      expiresAt: existing['Expires At'],
      issuedByDiscordId: existing['Issued By Discord ID']
    }), requestId);
    return pdv2Success_({ discordId: discordId, duplicateActiveNotice: true, noticeId: existing.NoticeId, notice: existing, summary: summary });
  }

  var appended = pdv2AppendActivityNoticeRecord_(Object.assign({}, data, { status: pdv2Pick_(data, ['status'], 'Active'), noticeType: noticeType }), requestId);
  var summaryResult = pdv2UpdateDatabaseActivityNoticeSummary_(Object.assign({}, data, {
    noticeLevel: appended.notice['Notice Level'],
    reason: appended.notice.Reason,
    issuedAt: appended.notice['Issued At'],
    expiresAt: appended.notice['Expires At'],
    issuedByDiscordId: appended.notice['Issued By Discord ID']
  }), requestId);
  pdv2Audit_(pdv2Pick_(data, ['source'], 'DISCORD_BOT'), 'ACTIVITY_NOTICE_ISSUED', pdv2Pick_(data, ['submittedByDiscordId', 'issuedByDiscordId'], ''), 'ActivityNotices', appended.noticeId, requestId || '', { discordId: discordId, noticeType: noticeType, noticeLevel: noticeLevel });
  return pdv2Success_({ discordId: discordId, noticeId: appended.noticeId, notice: appended.notice, summary: summaryResult });
}

function pdv2ResolveActivityNotice_(data, requestId) {
  data = data || {};
  var discordId = pdv2ActivityNoticeDiscordId_(data);
  if (!discordId) return pdv2Fail_('Missing Discord ID for activity notice resolve.');

  var noticeId = pdv2String_(pdv2Pick_(data, ['noticeId', 'NoticeId'], ''));
  var row = noticeId ? pdv2FindRowByValue_(PDV2.SHEETS.ACTIVITY_NOTICES, 'NoticeId', noticeId) : 0;
  if (!row) row = pdv2FindActiveActivityNoticeRow_(discordId, pdv2ActivityNoticeType_(data), pdv2Pick_(data, ['noticeLevel', 'strikeLevel'], ''));
  if (!row) {
    return pdv2Success_({ discordId: discordId, resolved: false, warning: 'No matching active activity notice found.' });
  }

  var now = pdv2Now_();
  var resolvedBy = pdv2Pick_(data, ['submittedByDiscordId', 'resolvedByDiscordId'], '');
  var saved = pdv2UpdateRowObject_(PDV2.SHEETS.ACTIVITY_NOTICES, row, {
    'Status': pdv2Pick_(data, ['status'], 'Resolved'),
    'Resolved At': pdv2Pick_(data, ['resolvedAt'], now),
    'Resolved By Discord ID': resolvedBy,
    'Updated At': now
  });
  var remainingRow = pdv2FindActiveActivityNoticeRow_(discordId, '', '');
  var summaryResult = remainingRow
    ? pdv2UpdateDatabaseActivityNoticeSummary_(pdv2RowToObject_(pdv2EnsureSheet_(PDV2.SHEETS.ACTIVITY_NOTICES), remainingRow), requestId)
    : pdv2UpdateDatabaseActivityNoticeSummary_(Object.assign({}, data, { clearSummary: true }), requestId);
  pdv2Audit_(pdv2Pick_(data, ['source'], 'DISCORD_BOT'), 'ACTIVITY_NOTICE_RESOLVED', resolvedBy, 'ActivityNotices', saved.NoticeId || noticeId, requestId || '', { discordId: discordId });
  return pdv2Success_({ discordId: discordId, noticeId: saved.NoticeId || noticeId, resolved: true, notice: saved, summary: summaryResult });
}

function pdv2AppendActivityNotice_(data, requestId) {
  return pdv2IssueActivityNotice_(data, requestId);
}
