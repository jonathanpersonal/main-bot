    'Request ID': requestId || ''
  });
  pdv2Audit_('DISCORD_BOT', 'DISCIPLINE_RECORD_CREATED', pdv2Pick_(data, ['submittedByDiscordId'], ''), 'DisciplineRecords', disciplineId, requestId || '', {});
